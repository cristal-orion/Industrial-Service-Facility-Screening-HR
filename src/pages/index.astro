<script>
  // ===== SCROLL ANIMATIONS =====
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // ===== HEADER SCROLL =====
  const header = document.getElementById('header');
  window.addEventListener('scroll', () => {
    header.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  // ===== POSIZIONI =====
  const POSITIONS = {
    qhse: 'QHSE Junior',
    gare: 'Responsabile Ufficio Gare',
    elettricista: 'Elettricista Trasfertista'
  };

  // ===== QUESTIONARIO ATTITUDINALE — 16 DOMANDE =====
  // Le 4 opzioni sono identiche per tutte le domande.
  const ANSWER_OPTIONS = [
    { label: 'Sì / più sì che no',        value: 'si',      color: 'green',  shape: 'triangle' },
    { label: 'Incerto / forse',           value: 'incerto', color: 'blue',   shape: 'circle'   },
    { label: 'No / più no che sì',        value: 'no',      color: 'orange', shape: 'square'   },
    { label: 'Preferisco non rispondere', value: 'na',      color: 'violet', shape: 'diamond'  }
  ];

  const SHAPE_SVG = {
    triangle: '<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><path d="M12 3 22 21 H2 Z" fill="currentColor"/></svg>',
    circle:   '<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><circle cx="12" cy="12" r="9" fill="currentColor"/></svg>',
    square:   '<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><rect x="4" y="4" width="16" height="16" rx="2" fill="currentColor"/></svg>',
    diamond:  '<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><path d="M12 2 22 12 12 22 2 12 Z" fill="currentColor"/></svg>'
  };

  const QUESTIONS = [
    { id: 1,  dim: 'Carisma & Influenza',                      text: 'Le persone si accendono e si entusiasmano quando ti ascoltano?' },
    { id: 2,  dim: 'Leadership naturale',                      text: 'Ci sono molte persone che ti seguirebbero ovunque, qualunque cosa tu decida di fare?' },
    { id: 3,  dim: 'Persuasione & Assertività',                text: 'Hai difficoltà a convincere gli altri ad accettare i tuoi progetti e le tue idee?' },
    { id: 4,  dim: 'Focus & Gestione delle distrazioni',       text: 'Le interferenze esterne riescono facilmente a distoglierti da ciò che stai facendo?' },
    { id: 5,  dim: 'Apertura sociale & Proattività',           text: 'Tendi a essere timido o riservato con persone che non conosci?' },
    { id: 6,  dim: 'Auto-consapevolezza & Growth Mindset',     text: 'Guardando al futuro, pensi che ci siano cose che dovresti affrontare in modo diverso?' },
    { id: 7,  dim: 'Organizzazione & Gestione del tempo',      text: 'Ti ritrovi spesso a completare le attività all’ultimo momento utile?' },
    { id: 8,  dim: 'Autostima & Barriere personali',           text: 'Senti che la timidezza limita spesso le tue possibilità o le tue scelte?' },
    { id: 9,  dim: 'Intelligenza Emotiva & Lettura situazioni',text: 'Quando qualcuno vuole incontrarti, riesci già in anticipo a intuire ciò che ti dirà?' },
    { id: 10, dim: 'Flessibilità & Collaborazione',            text: 'Preferisci che le cose vengano fatte esattamente come indichi, piuttosto che adattarti alle preferenze degli altri?' },
    { id: 11, dim: 'Umiltà & Consapevolezza dei limiti',       text: 'Ti capita di dire agli altri come fare le cose, anche in ambiti in cui la tua esperienza è limitata?' },
    { id: 12, dim: 'Valori & Etica della Leadership',          text: 'Un buon leader deve saper sacrificare il bene del singolo quando è necessario per il bene del gruppo?' },
    { id: 13, dim: 'Affinità col lavoro sul campo',            text: 'Lavorare principalmente in cantiere o in ambienti industriali, a contatto diretto con impianti e macchinari, ti entusiasma più che farlo da un ufficio?', section: 'Sezione settore — Industrial Service & Facility' },
    { id: 14, dim: 'Allineamento valoriale col settore',       text: 'Il tema dell’energia rinnovabile e della sostenibilità ambientale è qualcosa che senti vicino ai tuoi valori personali?' },
    { id: 15, dim: 'Flessibilità & Mobilità',                  text: 'Sei disponibile a spostarti frequentemente su tutto il territorio nazionale per seguire i progetti, anche per periodi prolungati?' },
    { id: 16, dim: 'Problem-solving & Resilienza operativa',   text: 'Quando sul lavoro emergono imprevisti tecnici o situazioni non pianificate, ti senti a tuo agio nel trovare soluzioni pratiche nell’immediato?' }
  ];

  // Endpoint webhook Apps Script
  const WEBHOOK_URL = 'https://script.google.com/macros/s/AKfycbxDOYJP9gd5iGmn14cPBKsZSuxGlA8zJAz3Bs4qx_rZwZYgZ-YhnlW-rFn0smyEdCcReg/exec';

  // ===== STATE =====
  // step -1 = intro, step 0 = contact, step 1..16 = domanda (1-based)
  let selectedPosition = null;
  let currentStep = -1;
  let contact = { nome: '', cognome: '', email: '', telefono: '', citta: '' };
  let answers = new Array(QUESTIONS.length).fill(null);

  const TOTAL_STEPS = QUESTIONS.length + 1; // contatti + 16 domande

  // ===== DOM =====
  const profilesGrid = document.getElementById('profilesGrid');
  const questionnaire = document.getElementById('questionnaire');
  const qBack = document.getElementById('qBack');
  const qProgress = document.getElementById('qProgress');
  const qProgressText = document.getElementById('qProgressText');
  const qProfileBadge = document.getElementById('qProfileBadge');
  const qQuestionWrap = document.getElementById('qQuestionWrap');
  const qStepLabel = document.getElementById('qStepLabel');
  const qQuestion = document.getElementById('qQuestion');
  const qHint = document.getElementById('qHint');
  const qOptions = document.getElementById('qOptions');
  const qProgressWrap = qProgress.closest('.q-progress-wrap');
  const resultScreen = document.getElementById('resultScreen');

  // ===== SELEZIONE POSIZIONE =====
  profilesGrid.addEventListener('click', (e) => {
    const card = e.target.closest('[data-profile]');
    if (!card) return;
    startQuiz(card.dataset.profile);
  });

  function startQuiz(positionKey) {
    selectedPosition = positionKey;
    currentStep = -1;
    contact = { nome: '', cognome: '', email: '', telefono: '', citta: '' };
    answers = new Array(QUESTIONS.length).fill(null);

    profilesGrid.style.display = 'none';
    resultScreen.style.display = 'none';
    questionnaire.style.display = 'block';
    qProfileBadge.textContent = POSITIONS[selectedPosition] || '';

    questionnaire.scrollIntoView({ behavior: 'smooth', block: 'center' });
    renderStep();
  }

  // ===== RENDER STEP =====
  function renderStep() {
    if (currentStep === -1) {
      qProgressWrap.style.visibility = 'hidden';
      qProgress.style.width = '0%';
    } else {
      qProgressWrap.style.visibility = 'visible';
      const pct = ((currentStep + 1) / TOTAL_STEPS) * 100;
      qProgress.style.width = pct + '%';
      qProgressText.innerHTML = `<span class="q-progress-current">${currentStep + 1}</span> / ${TOTAL_STEPS}`;
    }

    qQuestionWrap.style.animation = 'none';
    qQuestionWrap.offsetHeight;
    qQuestionWrap.style.animation = 'fadeIn 0.35s var(--ease-out-expo)';

    if (currentStep === -1) {
      renderIntroStep();
    } else if (currentStep === 0) {
      renderContactStep();
    } else {
      renderQuestionStep(currentStep - 1);
    }
  }

  function renderIntroStep() {
    qStepLabel.textContent = 'Prima di iniziare';
    qQuestion.textContent = 'Come funziona il questionario';
    qHint.textContent = '';
    qHint.style.display = 'none';
    qOptions.classList.remove('q-options--quiz');

    qOptions.innerHTML = `
      <div class="q-intro-steps">
        <div class="q-intro-step">
          <span class="q-intro-num">1</span>
          <div class="q-intro-text">
            <strong>I tuoi dati</strong>
            <span>Nome, contatti e posizione di interesse. Meno di un minuto.</span>
          </div>
        </div>
        <div class="q-intro-step">
          <span class="q-intro-num">2</span>
          <div class="q-intro-text">
            <strong>16 domande attitudinali</strong>
            <span>Una alla volta, con 4 opzioni di risposta. <em>Non ci sono risposte giuste o sbagliate</em>: rispondi onestamente, ci serve per capire l'affinità col ruolo.</span>
          </div>
        </div>
        <div class="q-intro-step">
          <span class="q-intro-num">3</span>
          <div class="q-intro-text">
            <strong>Esito</strong>
            <span>Se il tuo profilo è in linea con la posizione, il nostro team HR ti ricontatterà per i prossimi passi.</span>
          </div>
        </div>
      </div>
      <div class="q-intro-meta">
        <span class="q-intro-meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          ~ 5 minuti
        </span>
        <span class="q-intro-meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Dati protetti (GDPR)
        </span>
        <span class="q-intro-meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
          Puoi tornare indietro
        </span>
      </div>
      <button class="btn btn-primary q-submit" id="qIntroStart" type="button" style="width:100%;justify-content:center;">
        Inizia ora
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </button>
    `;
    document.getElementById('qIntroStart').addEventListener('click', () => {
      currentStep = 0;
      renderStep();
    });
  }

  function renderContactStep() {
    qStepLabel.textContent = 'I tuoi dati';
    qQuestion.textContent = 'Iniziamo con qualche informazione su di te';
    qHint.textContent = 'Useremo questi dati solo per ricontattarti.';
    qHint.style.display = '';
    qOptions.classList.remove('q-options--quiz');

    const positionOptions = Object.entries(POSITIONS)
      .map(([k, v]) => `<option value="${k}" ${k === selectedPosition ? 'selected' : ''}>${v}</option>`)
      .join('');

    qOptions.innerHTML = `
      <div class="q-input-row">
        <div class="q-input-group">
          <label for="qNome">Nome *</label>
          <input type="text" id="qNome" class="q-input" placeholder="Mario" value="${escapeAttr(contact.nome)}" required />
        </div>
        <div class="q-input-group">
          <label for="qCognome">Cognome *</label>
          <input type="text" id="qCognome" class="q-input" placeholder="Rossi" value="${escapeAttr(contact.cognome)}" required />
        </div>
      </div>
      <div class="q-input-group">
        <label for="qEmail">Email *</label>
        <input type="email" id="qEmail" class="q-input" placeholder="mario.rossi@email.com" value="${escapeAttr(contact.email)}" required />
      </div>
      <div class="q-input-row">
        <div class="q-input-group">
          <label for="qTelefono">Telefono *</label>
          <input type="tel" id="qTelefono" class="q-input" placeholder="+39 333 1234567" value="${escapeAttr(contact.telefono)}" required />
        </div>
        <div class="q-input-group">
          <label for="qCitta">Città *</label>
          <input type="text" id="qCitta" class="q-input" placeholder="Napoli" value="${escapeAttr(contact.citta)}" required />
        </div>
      </div>
      <div class="q-input-group">
        <label for="qPosizione">Posizione di interesse *</label>
        <select id="qPosizione" class="q-input">${positionOptions}</select>
      </div>
      <button class="btn btn-primary q-submit" id="qStart" style="width:100%;justify-content:center;">
        Inizia il questionario
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </button>
      <p class="q-privacy">Compilando il form acconsenti al trattamento dei tuoi dati per finalità di selezione. <br/>I dati verranno trattati nel rispetto del GDPR.</p>
    `;
    document.getElementById('qStart').addEventListener('click', handleContactSubmit);
  }

  function renderQuestionStep(qIndex) {
    const q = QUESTIONS[qIndex];
    qStepLabel.textContent = `Domanda ${qIndex + 1} di ${QUESTIONS.length}`;
    qQuestion.textContent = q.text;
    qHint.textContent = '';
    qHint.style.display = 'none';

    qOptions.innerHTML = '';
    qOptions.classList.add('q-options--quiz');
    ANSWER_OPTIONS.forEach((opt, i) => {
      const btn = document.createElement('button');
      btn.className = 'q-option q-option--quiz';
      btn.dataset.color = opt.color;
      btn.innerHTML = `
        <span class="q-option-shape">${SHAPE_SVG[opt.shape]}</span>
        <span class="q-option-label">${opt.label}</span>
        <span class="q-option-check" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
      `;
      if (answers[qIndex] && answers[qIndex].value === opt.value) {
        btn.classList.add('selected');
      }
      btn.addEventListener('click', () => handleAnswer(qIndex, opt.value, i));
      qOptions.appendChild(btn);
    });
  }

  function handleContactSubmit() {
    const nome = document.getElementById('qNome').value.trim();
    const cognome = document.getElementById('qCognome').value.trim();
    const email = document.getElementById('qEmail').value.trim();
    const telefono = document.getElementById('qTelefono').value.trim();
    const citta = document.getElementById('qCitta').value.trim();
    const posizione = document.getElementById('qPosizione').value;

    if (!nome || !cognome || !email || !telefono || !citta) {
      alert('Compila tutti i campi obbligatori.');
      return;
    }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      alert('Inserisci un indirizzo email valido.');
      return;
    }

    contact = { nome, cognome, email, telefono, citta };
    selectedPosition = posizione;
    qProfileBadge.textContent = POSITIONS[selectedPosition] || '';

    currentStep = 1;
    renderStep();
  }

  function handleAnswer(qIndex, value, optionIdx) {
    const opts = qOptions.querySelectorAll('.q-option');
    opts.forEach(o => o.classList.remove('selected'));
    opts[optionIdx].classList.add('selected');

    answers[qIndex] = { questionId: QUESTIONS[qIndex].id, value };

    setTimeout(() => {
      if (qIndex + 1 < QUESTIONS.length) {
        currentStep++;
        renderStep();
      } else {
        submitCandidatura();
      }
    }, 350);
  }

  async function submitCandidatura() {
    const payload = {
      posizione: POSITIONS[selectedPosition] || selectedPosition,
      posizioneKey: selectedPosition,
      contatto: contact,
      risposte: answers.map(a => a || { questionId: null, value: null }),
      timestamp: new Date().toISOString(),
      userAgent: navigator.userAgent
    };

    // Log temporaneo finché non c'è il webhook configurato
    console.log('Candidatura payload:', payload);

    let ok = true;
    if (WEBHOOK_URL) {
      try {
        const res = await fetch(WEBHOOK_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'text/plain;charset=utf-8' },
          body: JSON.stringify(payload)
        });
        ok = res.ok;
      } catch (err) {
        console.error('Errore invio candidatura:', err);
        ok = false;
      }
    }

    showThankYou(ok);
  }

  function showThankYou(success) {
    questionnaire.style.display = 'none';
    resultScreen.style.display = 'block';

    const icon = document.getElementById('resultIcon');
    icon.className = `result-icon ${success ? 'success' : 'warning'}`;
    if (success) {
      icon.innerHTML = `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
      document.getElementById('resultTitle').textContent = 'Grazie, abbiamo ricevuto la tua candidatura';
      document.getElementById('resultMessage').textContent = 'Il nostro team HR valuterà il tuo profilo nei prossimi giorni. Se sarà in linea con le nostre ricerche, ti contatteremo per i passi successivi.';
    } else {
      icon.innerHTML = `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`;
      document.getElementById('resultTitle').textContent = 'Qualcosa è andato storto';
      document.getElementById('resultMessage').textContent = 'Non siamo riusciti a inviare la candidatura. Riprova tra qualche minuto oppure scrivici via email.';
    }

    document.getElementById('resultScore').style.display = 'none';

    const btn = document.getElementById('resultBtn');
    btn.style.display = 'inline-flex';
    btn.textContent = success ? 'Torna alla home' : 'Riprova';
    btn.onclick = success ? resetAll : () => { resultScreen.style.display = 'none'; questionnaire.style.display = 'block'; };

    resultScreen.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  qBack.addEventListener('click', () => {
    if (currentStep <= -1) {
      resetAll();
    } else {
      currentStep--;
      renderStep();
    }
  });

  function resetAll() {
    selectedPosition = null;
    currentStep = -1;
    contact = { nome: '', cognome: '', email: '', telefono: '', citta: '' };
    answers = new Array(QUESTIONS.length).fill(null);
    questionnaire.style.display = 'none';
    resultScreen.style.display = 'none';
    profilesGrid.style.display = 'grid';
    profilesGrid.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function escapeAttr(s) {
    return String(s || '').replace(/"/g, '&quot;').replace(/</g, '&lt;');
  }
</script>
