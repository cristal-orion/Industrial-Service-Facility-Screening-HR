  function enrichMock(list) {
    return list.map(c => {
      const dims = computeDimensions(c.answers);
      const potenziale = computePotenziale(dims);
      const overall = computeOverall(dims);
      const categoria = categorize(dims);
      return { ...c, dims, potenziale, overall, categoria };
    });
  }

  // ============================================================
  // STATE
  // ============================================================
  let CANDIDATES = [];
  const state = {
    search: '',
    posizione: '',
    catActive: new Set(['pronti', 'diamante', 'medio', 'non_ora']),
    sort: { key: 'overall', dir: 'desc' }
  };

  // ============================================================
  // ELEMENTS
  // ============================================================
  const adminLogin = document.getElementById('adminLogin');
  const adminDash = document.getElementById('adminDash');
  const loginForm = document.getElementById('loginForm');
  const loginPassword = document.getElementById('loginPassword');
  const loginError = document.getElementById('loginError');
  const logoutBtn = document.getElementById('logoutBtn');
  const refreshBtn = document.getElementById('refreshBtn');

  const searchInput = document.getElementById('searchInput');
  const filterPosizione = document.getElementById('filterPosizione');
  const catToggles = document.getElementById('catToggles');
  const scatterWrap = document.getElementById('scatterWrap');
  const candTbody = document.getElementById('candTbody');
  const visibleCount = document.getElementById('visibleCount');

  const adminDetail = document.getElementById('adminDetail');
  const detailContent = document.getElementById('detailContent');
  const detailClose = document.getElementById('detailClose');
  const detailBackdrop = document.getElementById('detailBackdrop');

  // ============================================================
  // LOGIN
  // ============================================================
  async function apiCall(payload) {
    const res = await fetch(WEBHOOK_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'text/plain;charset=utf-8' },
      body: JSON.stringify(payload)
    });
    return res.json();
  }

  function getToken() {
    return sessionStorage.getItem(STORAGE_KEY);
  }

  async function checkSession() {
    const token = getToken();
    if (!token) return;
    await showDashboard();
  }

  loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    loginError.hidden = true;
    const submitBtn = loginForm.querySelector('button');
    const origBtn = submitBtn.innerHTML;
    submitBtn.disabled = true;
    submitBtn.innerHTML = 'Verifica…';

    try {
      const data = await apiCall({ action: 'login', password: loginPassword.value });
      if (data.ok && data.token) {
        sessionStorage.setItem(STORAGE_KEY, data.token);
        loginPassword.value = '';
        await showDashboard();
      } else {
        loginError.textContent = data.error === 'admin_not_configured'
          ? 'Backend non configurato (mancano le Script Properties).'
          : 'Password non corretta.';
        loginError.hidden = false;
        loginPassword.focus();
      }
    } catch (err) {
      loginError.textContent = 'Errore di rete. Riprova.';
      loginError.hidden = false;
      console.error(err);
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = origBtn;
    }
  });

  logoutBtn.addEventListener('click', () => {
    sessionStorage.removeItem(STORAGE_KEY);
    adminDash.hidden = true;
    adminLogin.hidden = false;
    loginPassword.value = '';
  });

  refreshBtn.addEventListener('click', async () => {
    refreshBtn.classList.add('spinning');
    await loadCandidates();
    renderAll();
    refreshBtn.classList.remove('spinning');
  });

  async function showDashboard() {
    adminLogin.hidden = true;
    adminDash.hidden = false;
    await loadCandidates();
    renderAll();
  }

  async function loadCandidates() {
    const token = getToken();
    if (!token) return;
    showLoading(true);
    try {
      const data = await apiCall({ action: 'list', token });
      if (data.ok && Array.isArray(data.candidates)) {
        CANDIDATES = data.candidates.map(c => ({
          ...c,
          dims: c.dims || computeDimensions((c.answers || []).map(a => a.value)),
        }));
      } else if (data.error === 'unauthorized') {
        // token scaduto/non valido → torna a login
        sessionStorage.removeItem(STORAGE_KEY);
        adminDash.hidden = true;
        adminLogin.hidden = false;
        return;
      } else {
        console.error('list error:', data);
        CANDIDATES = [];
      }
    } catch (err) {
      console.error('fetch error:', err);
      CANDIDATES = [];
    } finally {
      showLoading(false);
    }
  }

  function showLoading(on) {
    let el = document.getElementById('dashLoading');
    if (on) {
      if (!el) {
        el = document.createElement('div');
        el.id = 'dashLoading';
        el.className = 'dash-loading';
        el.innerHTML = '<div class="spinner"></div><p>Carico i candidati…</p>';
        adminDash.appendChild(el);
      }
      el.style.display = 'flex';
    } else if (el) {
      el.style.display = 'none';
    }
  }

