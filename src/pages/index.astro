  // ===== CARICAMENTO DINAMICO POSIZIONI =====
  function ralLabel(value) {
    // se il valore contiene cifre lo trattiamo come RAL; altrimenti "Contratto"
    return /\d/.test(String(value || '')) ? 'RAL' : 'Contratto';
  }

  function escapeHtml(s) {
    return String(s || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function renderProfilesGrid() {
    if (!POSITIONS_LIST.length) {
      profilesGrid.innerHTML = '<div class="profiles-empty">Nessuna posizione aperta al momento. Torna a trovarci presto.</div>';
      return;
    }
    const html = POSITIONS_LIST.map((p, i) => {
      const delay = Math.min(i + 1, 4); // riusa reveal-delay-1..4
      const icon = POSITION_ICONS[p.id] || POSITION_ICONS._default;
      const label = ralLabel(p.ral);
      return `
        <button class="profile-card reveal reveal-delay-${delay}" data-profile="${escapeHtml(p.id)}">
          <div class="card-top-accent"></div>
          <div class="profile-meta">
            <span class="badge badge-type">Full time</span>
            <span class="badge badge-location">
