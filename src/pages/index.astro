  let selectedPosition = null;
  let currentStep = -1;
  let contact = { nome: '', cognome: '', email: '', telefono: '', citta: '' };
  let answers = new Array(QUESTIONS.length).fill(null);
  let questionStartTime = 0;

  const TOTAL_STEPS = QUESTIONS.length + 1; // contatti + 16 domande

