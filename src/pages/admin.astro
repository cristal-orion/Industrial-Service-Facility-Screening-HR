    document.getElementById('kpiDiamanti').textContent = CANDIDATES.filter(c => c.categoria === 'diamante').length;
  }

  // ============================================================
  // SCATTER PLOT
  // ============================================================
  function renderScatter(list) {
    const W = scatterWrap.clientWidth || 600;
    const H = 420;
    const m = { top: 16, right: 20, bottom: 44, left: 48 };
    const iw = W - m.left - m.right;
    const ih = H - m.top - m.bottom;

    const xScale = v => m.left + (v / 100) * iw;
    const yScale = v => m.top + ih - (v / 100) * ih;

    const ticks = [0, 20, 40, 60, 80, 100];

    let svg = `<svg viewBox="0 0 ${W} ${H}" preserveAspectRatio="none">`;

    // grid
    for (const t of ticks) {
      svg += `<line class="scatter-grid" x1="${xScale(t)}" y1="${m.top}" x2="${xScale(t)}" y2="${m.top + ih}"/>`;
      svg += `<line class="scatter-grid" x1="${m.left}" y1="${yScale(t)}" x2="${m.left + iw}" y2="${yScale(t)}"/>`;
    }

    // quadrant background hint (50/50 lines stronger)
    svg += `<line class="scatter-axis-line" x1="${xScale(50)}" y1="${m.top}" x2="${xScale(50)}" y2="${m.top + ih}" stroke-dasharray="3 4"/>`;
    svg += `<line class="scatter-axis-line" x1="${m.left}" y1="${yScale(50)}" x2="${m.left + iw}" y2="${yScale(50)}" stroke-dasharray="3 4"/>`;

    // axes
    svg += `<line class="scatter-axis-line" x1="${m.left}" y1="${m.top + ih}" x2="${m.left + iw}" y2="${m.top + ih}"/>`;
    svg += `<line class="scatter-axis-line" x1="${m.left}" y1="${m.top}" x2="${m.left}" y2="${m.top + ih}"/>`;

    // ticks
    for (const t of ticks) {
      svg += `<text class="scatter-tick" x="${xScale(t)}" y="${m.top + ih + 18}" text-anchor="middle">${t}</text>`;
      svg += `<text class="scatter-tick" x="${m.left - 10}" y="${yScale(t) + 4}" text-anchor="end">${t}</text>`;
    }

    // labels
    svg += `<text class="scatter-axis-label" x="${m.left + iw / 2}" y="${H - 8}" text-anchor="middle">Fit settore</text>`;
    svg += `<text class="scatter-axis-label" transform="rotate(-90 14 ${m.top + ih / 2})" x="14" y="${m.top + ih / 2}" text-anchor="middle">Potenziale</text>`;

    // points
    for (const c of list) {
      const cx = xScale(c.dims.fitSettore);
      const cy = yScale(c.potenziale);
      const r = 6 + (c.overall / 100) * 6; // 6-12
      const color = CAT_COLORS[c.categoria];
      svg += `<circle class="scatter-point" data-id="${c.id}" cx="${cx}" cy="${cy}" r="${r}" fill="${color}" stroke="white" stroke-width="2"><title>${c.nome} ${c.cognome} — ${c.overall}/100</title></circle>`;
    }

    svg += '</svg>';
    scatterWrap.innerHTML = svg;

    scatterWrap.querySelectorAll('.scatter-point').forEach(p => {
      p.addEventListener('click', () => openDetail(p.dataset.id));
    });
  }

  window.addEventListener('resize', () => {
    if (!adminDash.hidden) renderScatter(filterCandidates());
  });

  // ============================================================
  // TABLE
  // ============================================================
  function renderTable(list) {
    const sorted = [...list].sort((a, b) => {
      const k = state.sort.key;
      let va = a[k], vb = b[k];
      if (k === 'nome') { va = a.nome + a.cognome; vb = b.nome + b.cognome; }
      if (va < vb) return state.sort.dir === 'asc' ? -1 : 1;
      if (va > vb) return state.sort.dir === 'asc' ? 1 : -1;
      return 0;
    });

    if (sorted.length === 0) {
      candTbody.innerHTML = `<tr class="empty-row"><td colspan="6">Nessun candidato corrisponde ai filtri.</td></tr>`;
      return;
    }

    candTbody.innerHTML = sorted.map(c => {
      const initials = (c.nome[0] + c.cognome[0]).toUpperCase();
      const fillColor = CAT_COLORS[c.categoria];
      const dateStr = new Date(c.timestamp).toLocaleDateString('it-IT', { day: '2-digit', month: 'short' });
      return `
        <tr data-id="${c.id}">
          <td>
            <div class="cand-name">
              <div class="cand-avatar">${initials}</div>
              <div>
                <strong>${c.nome} ${c.cognome}</strong>
                <small>${c.email}</small>
              </div>
            </div>
          </td>
          <td>${c.posizione}</td>
          <td>
            <div class="cand-score">${c.overall}<small style="color:#94a3b8;font-weight:500;font-size:0.78rem">/100</small></div>
            <div class="cand-score-bar"><i style="width:${c.overall}%;background:${fillColor}"></i></div>
          </td>
          <td><span class="cand-pill" data-cat="${c.categoria}">${CAT_LABELS[c.categoria]}</span></td>
          <td><small style="color:#64748b">${dateStr}</small></td>
          <td class="cand-chevron"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></td>
        </tr>
      `;
    }).join('');

    candTbody.querySelectorAll('tr[data-id]').forEach(tr => {
      tr.addEventListener('click', () => openDetail(tr.dataset.id));
    });
  }

  // sort headers
  document.querySelectorAll('.cand-table thead th[data-sort]').forEach(th => {
    th.addEventListener('click', () => {
      const k = th.dataset.sort;
      if (state.sort.key === k) {
        state.sort.dir = state.sort.dir === 'asc' ? 'desc' : 'asc';
      } else {
        state.sort.key = k;
        state.sort.dir = k === 'overall' ? 'desc' : 'asc';
      }
      renderAll();
    });
  });

  // ============================================================
  // DETTAGLIO
  // ============================================================
  function openDetail(id) {
    const c = CANDIDATES.find(x => x.id === id);
    if (!c) return;
    detailContent.innerHTML = renderDetail(c);
    adminDetail.hidden = false;
    document.body.style.overflow = 'hidden';
    // animate bars
    requestAnimationFrame(() => {
      detailContent.querySelectorAll('.d-bar-fill').forEach(el => {
        el.style.width = el.dataset.target;
      });
    });
  }

  function closeDetail() {
    adminDetail.hidden = true;
    document.body.style.overflow = '';
  }
  detailClose.addEventListener('click', closeDetail);
  detailBackdrop.addEventListener('click', closeDetail);
  adminDetail.addEventListener('click', (e) => {
    if (e.target === adminDetail) closeDetail();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !adminDetail.hidden) closeDetail();
  });

  function renderDetail(c) {
    const initials = (c.nome[0] + c.cognome[0]).toUpperCase();
    const dateStr = new Date(c.timestamp).toLocaleDateString('it-IT', {
      day: '2-digit', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit'
    });

    const dimEntries = Object.entries(DIM_LABELS);
    const barsHtml = dimEntries.map(([k, label]) => {
      const val = c.dims[k];
      return `
        <div class="d-bar-row">
          <div class="d-bar-label">${label}</div>
          <div class="d-bar-track"><div class="d-bar-fill" style="width:0;background:${DIM_COLORS[k]}" data-target="${val}%"></div></div>
          <div class="d-bar-val">${val}</div>
        </div>
      `;
    }).join('');

    const radar = renderRadarSVG(c.dims);

    const answersHtml = QUESTIONS.map(q => {
      const a = c.answers.find(x => x.questionId === q.id);
      const val = a ? a.value : null;
      const flag = a ? answerFlag(q, val) : 'na';
      const flagLabel = { ok: 'Ideale', warn: 'Da approfondire', crit: 'Critica', na: 'N/D' }[flag];
      return `
        <div class="d-answer-row">
          <div class="d-answer-num">Q${q.id}</div>
          <div class="d-answer-text">
            ${q.text}
            <small>${DIM_LABELS[q.dim]}</small>
          </div>
          <span class="d-answer-flag" data-flag="${flag}">${answerLabel(val)} · ${flagLabel}</span>
        </div>
      `;
    }).join('');

    return `
      <div class="d-content">
        <div class="d-header">
          <div class="d-avatar-row">
            <div class="d-avatar">${initials}</div>
            <div class="d-headline">
              <h2>${c.nome} ${c.cognome}</h2>
              <p>${c.posizione} · ${c.citta}</p>
            </div>
          </div>

          <div class="d-score-row">
            <div class="d-score-num">${c.overall}<small>/100</small></div>
            <div class="d-score-meta">
              <span class="cand-pill" data-cat="${c.categoria}">${CAT_LABELS[c.categoria]}</span>
              <p>Potenziale ${c.potenziale} · Fit settore ${c.dims.fitSettore}</p>
            </div>
          </div>

          <div class="d-contact-grid">
            <div class="d-contact-item"><label>Email</label><span>${c.email}</span></div>
            <div class="d-contact-item"><label>Telefono</label><span>${c.telefono}</span></div>
            <div class="d-contact-item"><label>Città</label><span>${c.citta}</span></div>
            <div class="d-contact-item"><label>Inviato il</label><span>${dateStr}</span></div>
          </div>
        </div>

        <div class="d-section">
          <h3 class="d-section-title">Profilo per dimensione</h3>
          <div class="d-charts">
            <div class="d-bars">${barsHtml}</div>
            ${radar}
          </div>
        </div>

        <div class="d-section">
          <h3 class="d-section-title">Risposte (${QUESTIONS.length})</h3>
          <div class="d-answers">${answersHtml}</div>
        </div>
      </div>
    `;
  }

  function renderRadarSVG(dims) {
    const size = 220;
    const cx = size / 2, cy = size / 2;
    const rMax = size / 2 - 30;
    const keys = ['relazionale', 'mindset', 'organizzazione', 'flessibilita', 'fitSettore'];
    const labels = ['Relaz.', 'Mindset', 'Organ.', 'Fless.', 'Fit'];
    const n = keys.length;

    function point(angle, ratio) {
      const x = cx + Math.cos(angle) * rMax * ratio;
      const y = cy + Math.sin(angle) * rMax * ratio;
      return [x, y];
    }

    // angoli da -90° (top), poi orario
    const angles = keys.map((_, i) => (-Math.PI / 2) + (i * 2 * Math.PI / n));

    let svg = `<svg class="d-radar" viewBox="0 0 ${size} ${size}" preserveAspectRatio="xMidYMid meet">`;

    // griglia concentrica (rings al 25/50/75/100)
    for (const r of [0.25, 0.5, 0.75, 1]) {
      const pts = angles.map(a => point(a, r).join(',')).join(' ');
      svg += `<polygon points="${pts}" fill="none" stroke="#e5e7eb" stroke-width="1"/>`;
    }

    // assi
    for (const a of angles) {
      const [x, y] = point(a, 1);
      svg += `<line x1="${cx}" y1="${cy}" x2="${x}" y2="${y}" stroke="#e5e7eb" stroke-width="1"/>`;
    }

    // dati
    const dataPts = keys.map((k, i) => point(angles[i], dims[k] / 100).join(',')).join(' ');
    svg += `<polygon points="${dataPts}" fill="rgba(13,158,113,0.18)" stroke="#0d9e71" stroke-width="2" stroke-linejoin="round"/>`;
    keys.forEach((k, i) => {
      const [x, y] = point(angles[i], dims[k] / 100);
      svg += `<circle cx="${x}" cy="${y}" r="3" fill="#0d9e71"/>`;
    });

    // label
    labels.forEach((lab, i) => {
      const [x, y] = point(angles[i], 1.18);
      svg += `<text x="${x}" y="${y + 3}" text-anchor="middle" font-size="10" font-family="Outfit, sans-serif" font-weight="600" fill="#475569">${lab}</text>`;
    });

    svg += '</svg>';
    return svg;
  }

  // ============================================================
  // INIT
  // ============================================================
  checkSession();
</script>
</Layout>
</content>
</invoke>