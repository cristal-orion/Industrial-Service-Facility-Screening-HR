---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lavora con noi — Industrial Service & Facility">

  <!-- HEADER -->
  <header class="header" id="header">
    <div class="container header-inner">
      <a href="https://www.industrialservicefacility.it/" class="logo-link" target="_blank" rel="noopener">
        <img
          src="https://www.industrialservicefacility.it/wp-content/uploads/2025/03/logo-gray-1.png"
          alt="Industrial Service & Facility"
          class="logo"
        />
      </a>
      <nav class="header-nav">
        <a href="#perche-noi" class="nav-link">Perché noi</a>
        <a href="#candidatura" class="nav-link">Posizioni aperte</a>
      </nav>
      <a href="#candidatura" class="header-cta">
        <span class="pulse-dot"></span>
        Stiamo assumendo
      </a>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-deco" aria-hidden="true">
      <div class="hero-circle hero-circle--1"></div>
      <div class="hero-circle hero-circle--2"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-left">
        <div class="hero-eyebrow reveal">
          <span class="eyebrow-tag">Energia rinnovabile</span>
          <span class="eyebrow-sep">/</span>
          <span>Dal 2017</span>
        </div>
        <h1 class="hero-title reveal reveal-delay-1">
          Costruisci il futuro<br/>dell'energia <span class="title-highlight">con noi</span>
        </h1>
        <p class="hero-sub reveal reveal-delay-2">
          Cerchiamo professionisti con esperienza nel settore fotovoltaico, eolico e impiantistico.
          Entra in un team che progetta, installa e mantiene gli impianti di domani.
        </p>
        <div class="hero-actions reveal reveal-delay-3">
          <a href="#candidatura" class="btn btn-primary btn-lg">
            Vedi posizioni aperte
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
      <div class="hero-right reveal reveal-delay-3">
        <figure class="hero-photo-card">
          <img
            src="/images/recruiting-hero-team.webp"
            alt="Tecnici Industrial Service & Facility al lavoro su un impianto fotovoltaico"
            class="hero-photo"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
          <figcaption class="hero-photo-caption">
            <span class="caption-kicker">Sul campo</span>
            <span>Fotovoltaico, eolico, impianti elettrici e manutenzione.</span>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- PERCHE NOI -->
  <section class="why-section" id="perche-noi">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">Perché sceglierci</span>
        <h2>Un ambiente dove crescere</h2>
      </div>
      <div class="why-visual reveal reveal-delay-1">
        <img
          src="/images/team-briefing-field.webp"
          alt="Team tecnico durante un briefing operativo in campo"
          class="why-visual-img"
          loading="lazy"
          decoding="async"
        />
        <div class="why-visual-copy">
          <span class="why-visual-tag">Squadra e metodo</span>
          <p>Affiancamento, procedure chiare e lavoro sul campo con persone esperte.</p>
        </div>
      </div>
      <div class="benefits-grid">
        <div class="benefit-card reveal reveal-delay-1">
          <div class="benefit-icon-wrap">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>Formazione continua</h3>
          <p>Investiamo sulla crescita professionale con corsi, certificazioni e affiancamento sul campo.</p>
        </div>
        <div class="benefit-card reveal reveal-delay-2">
          <div class="benefit-icon-wrap">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3>Team solido</h3>
          <p>Lavorerai con professionisti esperti in un ambiente collaborativo e strutturato.</p>
        </div>
        <div class="benefit-card reveal reveal-delay-3">
          <div class="benefit-icon-wrap">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3>Progetti innovativi</h3>
          <p>Fotovoltaico, eolico, impianti elettrici: tecnologie che contano per il pianeta.</p>
        </div>
        <div class="benefit-card reveal reveal-delay-4">
          <div class="benefit-icon-wrap">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Contratto e stabilità</h3>
          <p>Offriamo contratti stabili con retribuzione competitiva e benefit concreti.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- POSIZIONI APERTE -->
  <section class="positions-section" id="candidatura">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">Posizioni aperte</span>
        <h2>Trova il tuo ruolo</h2>
        <p class="section-desc">Scegli la posizione di interesse e completa un breve questionario attitudinale. Bastano 5 minuti.</p>
      </div>

      <!-- PROFILE CARDS -->
      <div class="profiles-grid" id="profilesGrid">
        <button class="profile-card reveal reveal-delay-1" data-profile="qhse">
          <div class="card-top-accent"></div>
          <div class="profile-meta">
            <span class="badge badge-type">Full time</span>
            <span class="badge badge-location">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Napoli
            </span>
          </div>
          <div class="profile-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4"/><path d="M12 2a10 10 0 110 20 10 10 0 010-20z"/></svg>
          </div>
          <h3>QHSE Junior</h3>
          <p>Supporto ai processi di qualità, salute, sicurezza e ambiente nel settore energia rinnovabile</p>
          <div class="profile-footer">
            <div class="profile-ral">
              <span class="ral-label">RAL</span>
              <span class="ral-value">&euro; 20.000 &ndash; 25.000</span>
            </div>
            <span class="profile-cta">
              Candidati
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </div>
        </button>

        <button class="profile-card reveal reveal-delay-2" data-profile="gare">
          <div class="card-top-accent"></div>
          <div class="profile-meta">
            <span class="badge badge-type">Full time</span>
            <span class="badge badge-location">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Napoli
            </span>
          </div>
          <div class="profile-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h3>Responsabile Ufficio Gare</h3>
          <p>Gestione e coordinamento delle procedure di gara e appalto per progetti nel settore energetico</p>
          <div class="profile-footer">
            <div class="profile-ral">
              <span class="ral-label">RAL</span>
              <span class="ral-value">&euro; 25.000 &ndash; 35.000</span>
            </div>
            <span class="profile-cta">
              Candidati
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </div>
        </button>

        <button class="profile-card reveal reveal-delay-3" data-profile="elettricista">
          <div class="card-top-accent"></div>
          <div class="profile-meta">
            <span class="badge badge-type">Full time</span>
            <span class="badge badge-location">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Napoli
            </span>
          </div>
          <div class="profile-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3>Elettricista Trasfertista</h3>
          <p>Installazione e manutenzione di impianti elettrici su cantieri fotovoltaici ed eolici in trasferta</p>
          <div class="profile-footer">
            <div class="profile-ral">
              <span class="ral-label">RAL</span>
              <span class="ral-value">&euro; 20.000 &ndash; 30.000</span>
            </div>
            <span class="profile-cta">
              Candidati
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </div>
        </button>
      </div>

      <!-- QUESTIONNAIRE -->
      <div class="questionnaire" id="questionnaire" style="display:none;">
        <div class="q-header">
          <button class="q-back" id="qBack" title="Torna indietro" type="button">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
            <span class="q-back-label">Indietro</span>
          </button>
          <div class="q-progress-wrap">
            <div class="q-progress-bar">
              <div class="q-progress-fill" id="qProgress"></div>
            </div>
            <span class="q-progress-text" id="qProgressText">1 / 5</span>
          </div>
          <span class="q-profile-badge" id="qProfileBadge"></span>
        </div>
        <div class="q-body" id="qBody">
          <div class="q-question-wrap" id="qQuestionWrap">
            <span class="q-step-label" id="qStepLabel"></span>
            <h3 class="q-question" id="qQuestion"></h3>
            <p class="q-hint" id="qHint"></p>
            <div class="q-options" id="qOptions"></div>
          </div>
        </div>
      </div>

      <!-- RISULTATO -->
      <div class="result" id="resultScreen" style="display:none;">
        <div class="result-card" id="resultCard">
          <div class="result-icon" id="resultIcon"></div>
          <h3 id="resultTitle"></h3>
          <p id="resultMessage"></p>
          <div class="result-score" id="resultScore" style="display:none;">
            <div class="score-bar">
              <div class="score-fill" id="scoreFill"></div>
            </div>
            <span class="score-text" id="scoreText"></span>
          </div>
          <button class="btn btn-primary" id="resultBtn" style="display:none;"></button>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-left">
        <img
          src="https://www.industrialservicefacility.it/wp-content/uploads/2025/03/logo-gray-1.png"
          alt="Industrial Service & Facility"
          class="footer-logo"
        />
        <p>Energia che costruisce valore, dal 2017.</p>
      </div>
      <div class="footer-right">
        <a href="https://www.industrialservicefacility.it/" target="_blank" rel="noopener" class="footer-link">
          Sito principale
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
      </div>
    </div>
  </footer>

</Layout>

<style is:global>
  /* ===== HEADER ===== */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-gray-200);
    transition: box-shadow 0.3s;
  }
  .header.scrolled {
    box-shadow: var(--shadow-sm);
  }
  .header-inner {
    max-width: 1140px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    padding: 0 28px;
  }
  .logo-link { display: flex; align-items: center; }
  .logo { height: 36px; width: auto; }
  .header-nav {
    display: flex;
    gap: 28px;
  }
  .nav-link {
    color: var(--color-gray-700);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-link:hover { color: var(--color-primary); }
  .header-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-primary);
    color: var(--color-white);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 8px 20px;
    border-radius: 100px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: all 0.25s;
  }
  .header-cta:hover {
    background: var(--color-primary-dark);
    box-shadow: 0 4px 16px rgba(13,158,113,0.25);
  }
  .pulse-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.9);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.4); }
  }

  /* ===== CONTAINER ===== */
  .container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 28px;
  }

  /* ===== HERO ===== */
  .hero {
    position: relative;
    padding: 140px 0 100px;
    background: var(--color-white);
    overflow: hidden;
  }
  .hero-deco {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .hero-circle {
    position: absolute;
    border-radius: 50%;
  }
  .hero-circle--1 {
    width: 500px;
    height: 500px;
    top: -120px;
    right: -80px;
    background: radial-gradient(circle, rgba(13,158,113,0.06) 0%, transparent 70%);
  }
  .hero-circle--2 {
    width: 300px;
    height: 300px;
    bottom: -60px;
    left: -40px;
    background: radial-gradient(circle, rgba(14,165,233,0.04) 0%, transparent 70%);
  }
  .hero-content {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 64px;
    align-items: center;
  }
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .eyebrow-tag {
    background: var(--color-primary-bg);
    padding: 4px 12px;
    border-radius: 100px;
  }
  .eyebrow-sep { color: var(--color-gray-400); }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4.5vw, 3.2rem);
    font-weight: 700;
    line-height: 1.12;
    color: var(--color-dark);
    letter-spacing: -0.025em;
    margin-bottom: 20px;
  }
  .title-highlight {
    color: var(--color-primary);
  }
  .hero-sub {
    font-size: 1.05rem;
    color: var(--color-gray-700);
    line-height: 1.75;
    margin-bottom: 36px;
    max-width: 500px;
  }
  .hero-actions { display: flex; gap: 14px; }

  .hero-photo-card {
    position: relative;
    min-height: 480px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid rgba(17, 17, 17, 0.08);
    box-shadow: 0 18px 48px rgba(17, 24, 39, 0.14);
    background: var(--color-gray-100);
  }
  .hero-photo {
    width: 100%;
    height: 100%;
    min-height: 480px;
    display: block;
    object-fit: cover;
    object-position: 58% center;
  }
  .hero-photo-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 48%, rgba(0,0,0,0.52) 100%);
    pointer-events: none;
  }
  .hero-photo-caption {
    position: absolute;
    left: 22px;
    right: 22px;
    bottom: 22px;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
    color: var(--color-white);
    font-size: 0.88rem;
    line-height: 1.45;
  }
  .caption-kicker {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.76);
  }

  /* ===== BUTTONS ===== */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.93rem;
    border: none;
    cursor: pointer;
    border-radius: var(--radius-md);
    transition: all 0.25s var(--ease-out-expo);
    text-decoration: none;
  }
  .btn-primary {
    background: var(--color-primary);
    color: var(--color-white);
    padding: 14px 28px;
  }
  .btn-primary:hover {
    background: var(--color-primary-dark);
    transform: translateY(-1px);
    box-shadow: 0 6px 24px rgba(13,158,113,0.2);
  }
  .btn-primary:active { transform: translateY(0); }
  .btn-lg {
    padding: 16px 32px;
    font-size: 0.95rem;
    border-radius: var(--radius-lg);
  }

  /* ===== SECTION COMMON ===== */
  .section-header { margin-bottom: 52px; }
  .section-tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    margin-bottom: 14px;
    padding: 5px 14px;
    border-radius: 100px;
    background: var(--color-primary-bg);
  }
  h2 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    font-weight: 700;
    color: var(--color-dark);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 12px;
  }
  .section-desc {
    font-size: 1rem;
    color: var(--color-gray-700);
    max-width: 460px;
    line-height: 1.65;
  }

  /* ===== WHY US ===== */
  .why-section {
    padding: 100px 0;
    background: var(--color-gray-50);
    border-top: 1px solid var(--color-gray-200);
    border-bottom: 1px solid var(--color-gray-200);
  }
  .why-visual {
    position: relative;
    min-height: 360px;
    margin-bottom: 28px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-gray-200);
    background: var(--color-gray-100);
  }
  .why-visual-img {
    width: 100%;
    height: 100%;
    min-height: 360px;
    display: block;
    object-fit: cover;
    object-position: center;
  }
  .why-visual::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.18) 42%, transparent 74%);
    pointer-events: none;
  }
  .why-visual-copy {
    position: absolute;
    left: 32px;
    bottom: 30px;
    z-index: 1;
    max-width: 340px;
    color: var(--color-white);
  }
  .why-visual-tag {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
    color: rgba(255,255,255,0.72);
  }
  .why-visual-copy p {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .benefit-card {
    padding: 32px 24px;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    transition: all 0.3s var(--ease-out-expo);
  }
  .benefit-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: rgba(13,158,113,0.2);
  }
  .benefit-icon-wrap {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary-bg);
    color: var(--color-primary);
    border-radius: var(--radius-md);
    margin-bottom: 20px;
  }
  .benefit-card h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-dark);
    margin-bottom: 8px;
  }
  .benefit-card p {
    font-size: 0.85rem;
    color: var(--color-gray-700);
    line-height: 1.6;
  }

  /* ===== POSITIONS ===== */
  .positions-section {
    padding: 100px 0 120px;
    background: var(--color-white);
  }

