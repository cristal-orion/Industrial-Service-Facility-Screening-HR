---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard HR — Industrial Service & Facility">
  <main class="admin">
    <!-- LOGIN -->
    <section class="admin-login" id="adminLogin">
      <div class="admin-login-card">
        <div class="admin-login-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h1>Dashboard HR</h1>
        <p>Accesso riservato al team di selezione.</p>
        <form id="loginForm" autocomplete="off">
          <input id="loginPassword" type="password" placeholder="Password" required />
          <button type="submit">
            Entra
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </button>
          <p class="admin-login-error" id="loginError" hidden>Password non corretta.</p>
        </form>
      </div>
    </section>

    <!-- DASHBOARD -->
    <section class="admin-dash" id="adminDash" hidden>
      <header class="admin-top">
        <div class="admin-top-left">
          <a href="/" class="admin-brand">
            <img src="https://www.industrialservicefacility.it/wp-content/uploads/2025/03/logo-gray-1.png" alt="ISF" />
          </a>
          <div>
            <h1>Dashboard candidature</h1>
            <p>Screening attitudinale · valutazione candidati</p>
          </div>
        </div>
        <div class="admin-top-right">
          <div class="admin-kpis">
            <div class="kpi"><span class="kpi-num" id="kpiTotal">0</span><span class="kpi-label">Totali</span></div>
            <div class="kpi"><span class="kpi-num" id="kpiPronti">0</span><span class="kpi-label">Pronti ora</span></div>
            <div class="kpi"><span class="kpi-num" id="kpiDiamanti">0</span><span class="kpi-label">Diamanti</span></div>
          </div>
          <button id="refreshBtn" class="admin-logout" title="Ricarica candidati">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
          </button>
          <button id="logoutBtn" class="admin-logout" title="Esci">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          </button>
        </div>
      </header>

      <div class="admin-controls">
        <div class="control-search">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input id="searchInput" type="search" placeholder="Cerca per nome o email…" />
        </div>
        <div class="control-filters">
          <select id="filterPosizione">
            <option value="">Tutte le posizioni</option>
            <option value="QHSE Junior">QHSE Junior</option>
            <option value="Responsabile Ufficio Gare">Responsabile Ufficio Gare</option>
            <option value="Elettricista Trasfertista">Elettricista Trasfertista</option>
          </select>
          <div class="cat-toggles" id="catToggles">
            <button data-cat="pronti" class="cat-toggle active" data-color="green">Pronti ora</button>
            <button data-cat="diamante" class="cat-toggle active" data-color="blue">Diamante grezzo</button>
            <button data-cat="medio" class="cat-toggle active" data-color="amber">Potenziale medio</button>
            <button data-cat="non_ora" class="cat-toggle active" data-color="gray">Non ora</button>
          </div>
        </div>
      </div>

      <div class="admin-grid">
        <div class="panel panel-chart">
          <div class="panel-head">
            <h2>Mappa candidati</h2>
            <p>Skill tecnica/fit settore <span>(asse X)</span> vs Potenziale <span>(asse Y)</span>. Clicca un punto per il dettaglio.</p>
          </div>
          <div class="scatter-wrap" id="scatterWrap"></div>
          <div class="scatter-legend">
            <span><i style="background:#16a34a"></i> Pronti ora</span>
            <span><i style="background:#0284c7"></i> Diamante grezzo</span>
            <span><i style="background:#d97706"></i> Potenziale medio</span>
            <span><i style="background:#94a3b8"></i> Non ora</span>
          </div>
        </div>

        <div class="panel panel-table">
          <div class="panel-head">
            <h2>Elenco candidati</h2>
            <p><span id="visibleCount">0</span> visibili</p>
          </div>
          <div class="table-wrap">
            <table class="cand-table">
              <thead>
                <tr>
                  <th data-sort="nome">Candidato</th>
                  <th data-sort="posizione">Posizione</th>
                  <th data-sort="overall">Score</th>
                  <th data-sort="categoria">Categoria</th>
                  <th data-sort="timestamp">Data</th>
                  <th></th>
                </tr>
              </thead>
              <tbody id="candTbody"></tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <!-- DETTAGLIO -->
    <aside class="admin-detail" id="adminDetail" hidden>
      <div class="detail-backdrop" id="detailBackdrop"></div>
      <div class="detail-panel">
        <button class="detail-close" id="detailClose" title="Chiudi">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <div id="detailContent"></div>
      </div>
    </aside>
  </main>
</Layout>

<style is:global>
  body { background: #f6f7f9; }

  [hidden] { display: none !important; }

  .admin { min-height: 100vh; }

  /* ===== LOGIN ===== */
  .admin-login {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background:
      radial-gradient(circle at 20% 10%, rgba(13,158,113,0.08), transparent 50%),
      radial-gradient(circle at 80% 90%, rgba(14,165,233,0.06), transparent 50%),
      #f6f7f9;
  }
  .admin-login-card {
    width: 100%;
    max-width: 380px;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 22px;
    padding: 40px 32px 32px;
    text-align: center;
    box-shadow: 0 20px 50px rgba(15,23,42,0.08);
  }
  .admin-login-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--color-primary-bg);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 18px;
  }
  .admin-login-card h1 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 6px;
  }
  .admin-login-card p {
    font-size: 0.88rem;
    color: var(--color-gray-500);
    margin-bottom: 24px;
  }
  #loginForm { display: flex; flex-direction: column; gap: 12px; }
  #loginPassword {
    width: 100%;
    padding: 14px 16px;
    border: 2px solid #d1d5db;
    border-radius: 12px;
    font-size: 1rem;
    font-family: var(--font-body);
    background: var(--color-white);
  }
  #loginPassword:focus {
    outline: none;
    border-color: var(--color-primary);
  }
  #loginForm button {
    padding: 14px 22px;
    background: var(--color-primary);
    color: var(--color-white);
    border: none;
    border-radius: 12px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: background 0.2s;
  }
  #loginForm button:hover { background: var(--color-primary-dark); }
  .admin-login-error {
    color: var(--color-danger) !important;
    font-size: 0.84rem !important;
    margin-top: 4px !important;
    margin-bottom: 0 !important;
  }

  /* ===== DASHBOARD ===== */
  .admin-dash { padding: 24px 28px 80px; max-width: 1480px; margin: 0 auto; }

  .admin-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 18px 24px;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 18px;
    margin-bottom: 22px;
    box-shadow: 0 1px 2px rgba(15,23,42,0.04);
  }
  .admin-top-left {
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .admin-brand { display: flex; align-items: center; }
  .admin-brand img { height: 32px; opacity: 0.85; }
  .admin-top-left h1 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-dark);
    line-height: 1.1;
  }
  .admin-top-left p {
    font-size: 0.82rem;
    color: var(--color-gray-500);
    margin-top: 2px;
  }
  .admin-top-right {
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .admin-kpis {
    display: flex;
    gap: 22px;
    padding-right: 18px;
    border-right: 1px solid var(--color-gray-200);
  }
  .kpi { text-align: right; line-height: 1; }
  .kpi-num {
    display: block;
    font-family: var(--font-display);
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: -0.02em;
  }
  .kpi-label {
    display: block;
    font-size: 0.7rem;
    color: var(--color-gray-500);
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }
  .admin-logout {
    background: var(--color-gray-100);
    border: none;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-gray-700);
    transition: all 0.2s;
  }
  .admin-logout:hover { background: var(--color-gray-200); color: var(--color-dark); }
  .admin-logout.spinning svg {
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .dash-loading {
    position: fixed;
    inset: 0;
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(4px);
    z-index: 150;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    color: var(--color-gray-700);
  }
  .dash-loading p {
    font-size: 0.9rem;
    color: var(--color-gray-500);
  }
  .spinner {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 3px solid var(--color-gray-200);
    border-top-color: var(--color-primary);
    animation: spin 0.7s linear infinite;
  }

  /* CONTROLS */
  .admin-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }
  .control-search {
    position: relative;
    flex: 0 1 360px;
  }
  .control-search svg {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-gray-400);
    pointer-events: none;
  }
  .control-search input {
    width: 100%;
    padding: 11px 14px 11px 40px;
    background: var(--color-white);
    border: 1.5px solid var(--color-gray-200);
    border-radius: 10px;
    font-family: var(--font-body);
    font-size: 0.92rem;
  }
  .control-search input:focus {
    outline: none;
    border-color: var(--color-primary);
  }
  .control-filters {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  #filterPosizione {
    padding: 10px 32px 10px 14px;
    border: 1.5px solid var(--color-gray-200);
    border-radius: 10px;
    background: var(--color-white);
    font-family: var(--font-body);
    font-size: 0.88rem;
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6'><path d='M1 1l4 4 4-4' stroke='%23666' stroke-width='1.5' fill='none' stroke-linecap='round'/></svg>");
    background-repeat: no-repeat;
    background-position: right 12px center;
  }
  .cat-toggles { display: flex; gap: 6px; }
  .cat-toggle {
    padding: 8px 14px;
    border: 1.5px solid var(--color-gray-200);
    background: var(--color-white);
    border-radius: 100px;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--color-gray-500);
  }
  .cat-toggle::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.35;
  }
  .cat-toggle.active { color: var(--color-dark); border-color: currentColor; }
  .cat-toggle.active::before { opacity: 1; }
  .cat-toggle[data-color="green"] { color: #16a34a; }
  .cat-toggle[data-color="blue"]  { color: #0284c7; }
  .cat-toggle[data-color="amber"] { color: #d97706; }
  .cat-toggle[data-color="gray"]  { color: #64748b; }
  .cat-toggle:not(.active) { color: var(--color-gray-400); }
  .cat-toggle:not(.active)::before { background: var(--color-gray-400); }

  /* GRID */
  .admin-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(0, 1fr);
    gap: 22px;
  }
  .panel {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 18px;
    padding: 22px;
    box-shadow: 0 1px 2px rgba(15,23,42,0.03);
  }
  .panel-head { margin-bottom: 16px; }
  .panel-head h2 {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 4px;
  }
  .panel-head p {
    font-size: 0.8rem;
    color: var(--color-gray-500);
  }
  .panel-head p span { color: var(--color-gray-400); }

  /* SCATTER */
  .scatter-wrap {
    width: 100%;
    height: 420px;
    position: relative;
  }
  .scatter-wrap svg { width: 100%; height: 100%; display: block; overflow: visible; }
  .scatter-point {
    cursor: pointer;
    transition: r 0.2s, stroke-width 0.2s, filter 0.2s;
    filter: drop-shadow(0 2px 4px rgba(15,23,42,0.15));
  }
  .scatter-point:hover {
    stroke-width: 3;
    filter: drop-shadow(0 4px 10px rgba(15,23,42,0.3));
  }
  .scatter-axis-line { stroke: #e5e7eb; stroke-width: 1; }
  .scatter-grid { stroke: #f1f5f9; stroke-width: 1; }
  .scatter-tick {
    font-family: var(--font-display);
    font-size: 11px;
    fill: #94a3b8;
  }
  .scatter-axis-label {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 600;
    fill: #475569;
  }
  .scatter-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 12px;
    padding-top: 14px;
    border-top: 1px solid var(--color-gray-100);
    font-size: 0.78rem;
    color: var(--color-gray-700);
  }
  .scatter-legend span { display: inline-flex; align-items: center; gap: 6px; }
  .scatter-legend i {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  /* TABLE */
  .table-wrap {
    overflow-x: auto;
    margin: 0 -22px -22px;
    padding: 0 22px 22px;
  }
  .cand-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }
  .cand-table thead th {
    text-align: left;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-500);
    padding: 10px 12px;
    border-bottom: 1px solid var(--color-gray-200);
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
  }
  .cand-table thead th:hover { color: var(--color-dark); }
  .cand-table tbody tr {
    transition: background 0.15s;
    cursor: pointer;
  }
  .cand-table tbody tr:hover { background: var(--color-gray-50); }
  .cand-table tbody td {
    padding: 14px 12px;
    border-bottom: 1px solid var(--color-gray-100);
    color: var(--color-gray-700);
    vertical-align: middle;
  }
  .cand-name {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .cand-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-primary-bg);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.78rem;
    font-family: var(--font-display);
    flex-shrink: 0;
  }
  .cand-name strong {
    display: block;
    color: var(--color-dark);
    font-weight: 600;
    font-size: 0.92rem;
  }
  .cand-name small {
    color: var(--color-gray-500);
    font-size: 0.78rem;
  }
  .cand-score {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-dark);
    font-size: 1rem;
  }
  .cand-score-bar {
    width: 60px;
    height: 4px;
    background: var(--color-gray-100);
    border-radius: 2px;
    margin-top: 4px;
    overflow: hidden;
  }
  .cand-score-bar i {
    display: block;
    height: 100%;
    border-radius: 2px;
  }
  .cand-pill {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 100px;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .cand-pill[data-cat="pronti"]   { background: rgba(22,163,74,0.1);  color: #16a34a; }
  .cand-pill[data-cat="diamante"] { background: rgba(2,132,199,0.1);  color: #0284c7; }
  .cand-pill[data-cat="medio"]    { background: rgba(217,119,6,0.1);  color: #d97706; }
  .cand-pill[data-cat="non_ora"]  { background: rgba(100,116,139,0.1);color: #64748b; }
  .cand-chevron {
    color: var(--color-gray-400);
    text-align: right;
  }
  .empty-row td {
    text-align: center;
    color: var(--color-gray-400);
    padding: 40px 12px;
    font-size: 0.9rem;
  }

  /* DETTAGLIO — MODALE CENTRALE */
  .admin-detail {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 28px;
  }
  .detail-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15,23,42,0.55);
    backdrop-filter: blur(6px);
    animation: dFade 0.22s ease-out;
    cursor: pointer;
  }
  .detail-panel {
    position: relative;
    width: 100%;
    max-width: 920px;
    max-height: calc(100vh - 56px);
    background: var(--color-white);
    border-radius: 22px;
    overflow-y: auto;
    box-shadow: 0 30px 80px rgba(15,23,42,0.35), 0 0 0 1px rgba(255,255,255,0.05);
    animation: dPop 0.32s var(--ease-out-expo);
  }
  @keyframes dFade { from { opacity: 0; } to { opacity: 1; } }
  @keyframes dPop {
    from { transform: translateY(16px) scale(0.96); opacity: 0; }
    to   { transform: translateY(0) scale(1); opacity: 1; }
  }
  .detail-close {
    position: absolute;
    top: 18px;
    right: 18px;
    width: 40px;
    height: 40px;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 12px;
    cursor: pointer;
    color: var(--color-gray-700);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    z-index: 3;
    box-shadow: 0 4px 14px rgba(15,23,42,0.08);
  }
  .detail-close:hover {
    background: var(--color-gray-100);
    color: var(--color-dark);
    transform: scale(1.05);
  }

  .d-content { padding: 36px 36px 56px; }
  .d-header { margin-bottom: 28px; }
  .d-avatar-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
  }
  .d-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.4rem;
    flex-shrink: 0;
  }
  .d-headline h2 {
    font-family: var(--font-display);
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--color-dark);
    margin: 0;
    line-height: 1.15;
  }
  .d-headline p {
    color: var(--color-gray-500);
    font-size: 0.9rem;
    margin-top: 4px;
  }
  .d-score-row {
    display: flex;
