  // ============================================================
  // SCORING
  // ============================================================
  function scoreAnswer(q, value) {
    if (value === q.ideal) return 100;
    if (value === 'incerto') return 50;
    if (value === 'na') return 25;
    return q.critical === value ? 0 : 20;
  }

  function answerFlag(q, value) {
    if (value === q.ideal) return 'ok';
    if (value === 'incerto') return 'warn';
    if (value === 'na') return 'na';
    return q.critical === value ? 'crit' : 'warn';
  }

  function answerLabel(value) {
    return { si: 'Sì', incerto: 'Incerto', no: 'No', na: 'Non risp.' }[value] || value;
  }

  function computeDimensions(answers) {
    const dims = { relazionale: [], mindset: [], organizzazione: [], flessibilita: [], fitSettore: [] };
    for (const q of QUESTIONS) {
      const a = answers.find(x => x.questionId === q.id);
      if (a) dims[q.dim].push(scoreAnswer(q, a.value));
    }
    const out = {};
    for (const k in dims) {
      const arr = dims[k];
      out[k] = arr.length ? Math.round(arr.reduce((s, v) => s + v, 0) / arr.length) : 0;
    }
    return out;
  }

  function computePotenziale(dims) {
    const v = [dims.relazionale, dims.mindset, dims.organizzazione, dims.flessibilita];
    return Math.round(v.reduce((s, x) => s + x, 0) / v.length);
  }

  function computeOverall(dims) {
    const v = Object.values(dims);
    return Math.round(v.reduce((s, x) => s + x, 0) / v.length);
  }

  function categorize(dims) {
    const fit = dims.fitSettore;
    const pot = computePotenziale(dims);
    if (fit >= 65 && pot >= 65) return 'pronti';
    if (fit < 50 && pot >= 65) return 'diamante';
    if (fit < 50 && pot < 50)  return 'non_ora';
    return 'medio';
  }

