          <h3>${escapeHtml(p.titolo)}</h3>
          <p>${escapeHtml(p.descrizione)}</p>
          <div class="profile-footer">
            <div class="profile-ral">
              <span class="ral-label">${label}</span>
              <span class="ral-value">${escapeHtml(p.ral || '—')}</span>
