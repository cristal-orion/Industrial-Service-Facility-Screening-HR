---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lavora con noi — Industrial Service & Facility">

  <!-- HEADER -->
  <header class="header" id="header">
    <div class="container header-inner">
      <a href="https://www.industrialservicefacility.it/" class="logo-link" target="_blank" rel="noopener">
        <img
          src="https://www.industrialservicefacility.it/wp-content/uploads/2025/03/logo-gray-1.png"
          alt="Industrial Service & Facility"
          class="logo"
        />
      </a>
      <nav class="header-nav">
        <a href="#perche-noi" class="nav-link">Perché noi</a>
        <a href="#candidatura" class="nav-link">Trova il tuo ruolo</a>
      </nav>
      <a href="#candidatura" class="header-cta">
        <span class="pulse-dot"></span>
        Stiamo assumendo
      </a>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-deco" aria-hidden="true">
      <div class="hero-circle hero-circle--1"></div>
      <div class="hero-circle hero-circle--2"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-left">
        <div class="hero-eyebrow reveal">
          <span class="eyebrow-tag">Energia rinnovabile</span>
          <span class="eyebrow-sep">/</span>
          <span>Dal 2017</span>
        </div>
        <h1 class="hero-title reveal reveal-delay-1">
          Costruisci il futuro<br/>dell'energia <span class="title-highlight">con noi - is Facility!</span>
        </h1>
        <p class="hero-sub reveal reveal-delay-2">
          Cerchiamo professionisti con esperienza nel settore fotovoltaico, eolico e impiantistico.
          Entra in un team che progetta, installa e mantiene gli impianti di domani.
        </p>
        <div class="hero-actions reveal reveal-delay-3">
          <a href="#candidatura" class="btn btn-primary btn-lg">
            Vedi posizioni aperte
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
      <div class="hero-right reveal reveal-delay-3">
        <figure class="hero-photo-card">
          <img
            src="/images/recruiting-hero-team.webp"
            alt="Tecnici Industrial Service & Facility al lavoro su un impianto fotovoltaico"
            class="hero-photo"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
          <figcaption class="hero-photo-caption">
            <span class="caption-kicker">Sul campo</span>
            <span>Fotovoltaico, eolico, impianti elettrici e manutenzione.</span>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- PERCHE NOI -->
  <section class="why-section" id="perche-noi">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">Perché sceglierci</span>
        <h2>Un ambiente dove crescere</h2>
      </div>
      <div class="why-visual reveal reveal-delay-1">
        <img
          src="/images/foto-reali/team-fiera.webp"
          alt="Il team Industrial Service & Facility allo stand fieristico"
          class="why-visual-img"
          loading="lazy"
          decoding="async"
        />
        <div class="why-visual-copy">
          <span class="why-visual-tag">Squadra e metodo</span>
          <p>Affiancamento, procedure chiare e lavoro sul campo con persone esperte.</p>
        </div>
      </div>
      <div class="benefits-grid">
        <div class="benefit-card reveal reveal-delay-1">
          <div class="benefit-icon-wrap">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>Formazione continua</h3>
          <p>Investiamo sulla crescita professionale con corsi, certificazioni e affiancamento sul campo.</p>
        </div>
        <div class="benefit-card reveal reveal-delay-2">
          <div class="benefit-icon-wrap">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3>Team solido</h3>
          <p>Lavorerai con professionisti esperti in un ambiente collaborativo e strutturato.</p>
        </div>
        <div class="benefit-card reveal reveal-delay-3">
          <div class="benefit-icon-wrap">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3>Progetti innovativi</h3>
          <p>Fotovoltaico, eolico, impianti elettrici: tecnologie che contano per il pianeta.</p>
        </div>
        <div class="benefit-card reveal reveal-delay-4">
          <div class="benefit-icon-wrap">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Contratto e stabilità</h3>
          <p>Offriamo contratti stabili con retribuzione competitiva e benefit concreti.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- I NOSTRI CANTIERI -->
  <section class="gallery-section" id="cantieri">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">I nostri cantieri</span>
        <h2>Dove lavorerai</h2>
        <p class="section-desc">Eolico, fotovoltaico, impianti elettrici: ecco i contesti reali in cui operano le nostre squadre.</p>
      </div>

      <div class="gallery reveal reveal-delay-1">
        <button class="gallery-nav gallery-nav-prev" type="button" aria-label="Foto precedente">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>

        <div class="gallery-track" id="galleryTrack">
          <div class="gallery-marquee">
            <div class="gallery-set">
              <figure class="gallery-slide">
                <img src="/images/foto-reali/operatori-spalle.webp" alt="Operatori Industrial Service & Facility in cantiere" loading="lazy" decoding="async" />
                <figcaption>Squadre operative sul campo</figcaption>
              </figure>
              <figure class="gallery-slide">
                <img src="/images/foto-reali/eolico-tecnico.webp" alt="Tecnico in manutenzione su pala eolica" loading="lazy" decoding="async" />
                <figcaption>Manutenzione eolica in quota</figcaption>
              </figure>
              <figure class="gallery-slide">
                <img src="/images/foto-reali/eolico-panorama.webp" alt="Vista panoramica da una pala eolica" loading="lazy" decoding="async" />
                <figcaption>Il punto di vista del tecnico eolico</figcaption>
              </figure>
              <figure class="gallery-slide">
                <img src="/images/foto-reali/fotovoltaico.webp" alt="Impianto fotovoltaico Industrial Service & Facility" loading="lazy" decoding="async" />
                <figcaption>Parchi fotovoltaici O&amp;M</figcaption>
              </figure>
              <figure class="gallery-slide">
                <img src="/images/foto-reali/sede.webp" alt="Ingresso della sede Industrial Service & Facility" loading="lazy" decoding="async" />
                <figcaption>La nostra sede</figcaption>
              </figure>
              <figure class="gallery-slide">
                <img src="/images/foto-reali/stand-fiera.webp" alt="Stand Industrial Service & Facility in fiera" loading="lazy" decoding="async" />
                <figcaption>Industrial Service &amp; Facility in fiera</figcaption>
              </figure>
            </div>
            <div class="gallery-set" aria-hidden="true">
              <figure class="gallery-slide"><img src="/images/foto-reali/operatori-spalle.webp" alt="" loading="lazy" decoding="async" /><figcaption>Squadre operative sul campo</figcaption></figure>
              <figure class="gallery-slide"><img src="/images/foto-reali/eolico-tecnico.webp" alt="" loading="lazy" decoding="async" /><figcaption>Manutenzione eolica in quota</figcaption></figure>
              <figure class="gallery-slide"><img src="/images/foto-reali/eolico-panorama.webp" alt="" loading="lazy" decoding="async" /><figcaption>Il punto di vista del tecnico eolico</figcaption></figure>
              <figure class="gallery-slide"><img src="/images/foto-reali/fotovoltaico.webp" alt="" loading="lazy" decoding="async" /><figcaption>Parchi fotovoltaici O&amp;M</figcaption></figure>
              <figure class="gallery-slide"><img src="/images/foto-reali/sede.webp" alt="" loading="lazy" decoding="async" /><figcaption>La nostra sede</figcaption></figure>
              <figure class="gallery-slide"><img src="/images/foto-reali/stand-fiera.webp" alt="" loading="lazy" decoding="async" /><figcaption>Industrial Service &amp; Facility in fiera</figcaption></figure>
            </div>
          </div>
        </div>

        <button class="gallery-nav gallery-nav-next" type="button" aria-label="Foto successiva">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- POSIZIONI APERTE -->
  <section class="positions-section" id="candidatura">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">Posizioni aperte</span>
        <h2>Trova il tuo ruolo</h2>
        <p class="section-desc">Scegli la posizione di interesse e completa un breve questionario attitudinale. Bastano 5 minuti.</p>
      </div>

      <!-- PROFILE CARDS (renderizzate dinamicamente) -->
      <div class="profiles-grid" id="profilesGrid">
        <div class="profiles-loading" id="profilesLoading">
          <div class="profiles-spinner"></div>
          <p>Carico le posizioni aperte…</p>
        </div>
      </div>

      <!-- QUESTIONNAIRE -->
      <div class="questionnaire" id="questionnaire" style="display:none;">
        <div class="q-header">
          <button class="q-back" id="qBack" title="Torna indietro" type="button">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
            <span class="q-back-label">Indietro</span>
          </button>
          <div class="q-progress-wrap">
            <div class="q-progress-bar">
              <div class="q-progress-fill" id="qProgress"></div>
            </div>
            <span class="q-progress-text" id="qProgressText">1 / 5</span>
          </div>
          <span class="q-profile-badge" id="qProfileBadge"></span>
        </div>
        <div class="q-body" id="qBody">
          <div class="q-question-wrap" id="qQuestionWrap">
            <span class="q-step-label" id="qStepLabel"></span>
            <h3 class="q-question" id="qQuestion"></h3>
            <p class="q-hint" id="qHint"></p>
            <div class="q-options" id="qOptions"></div>
          </div>
        </div>
      </div>

      <!-- RISULTATO -->
      <div class="result" id="resultScreen" style="display:none;">
        <div class="result-card" id="resultCard">
          <div class="result-icon" id="resultIcon"></div>
          <h3 id="resultTitle"></h3>
          <p id="resultMessage"></p>
          <div class="result-score" id="resultScore" style="display:none;">
            <div class="score-bar">
              <div class="score-fill" id="scoreFill"></div>
            </div>
            <span class="score-text" id="scoreText"></span>
          </div>
          <button class="btn btn-primary" id="resultBtn" style="display:none;"></button>

          <div class="result-invite" id="resultInvite" style="display:none;">
            <div class="result-invite-divider"></div>
            <p class="result-invite-title">Conosci qualcuno che potrebbe essere interessato?</p>
            <div class="invite-share-row">
              <input class="invite-url" id="resultInviteUrl" readonly />
              <button class="btn btn-primary invite-copy-btn" data-target="resultInviteUrl" data-status="resultInviteStatus" type="button">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                Copia link
              </button>
            </div>
            <p class="invite-status" id="resultInviteStatus"></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INVITA UN AMICO -->
  <section class="invite-section" id="invita-amico">
    <div class="container">
      <div class="invite-card">
        <div class="invite-card-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
        </div>
        <div class="invite-card-body">
          <h2 class="invite-title">Conosci qualcuno che potrebbe essere interessato?</h2>
          <p class="invite-desc">Aiutaci a far crescere il team. Copia il link qui sotto e inviallo a chi pensi possa fare al caso nostro: le posizioni aperte sono visibili a tutti.</p>
          <div class="invite-share-row">
            <input class="invite-url" id="inviteUrl" readonly />
            <button class="btn btn-primary invite-copy-btn" id="inviteCopyBtn" data-target="inviteUrl" data-status="inviteStatus" type="button">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              Copia link
            </button>
            <button class="btn btn-secondary invite-share-btn" id="inviteShareBtn" data-target="inviteUrl" type="button" style="display:none;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
              Condividi
            </button>
          </div>
          <p class="invite-status" id="inviteStatus"></p>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-left">
        <img
          src="https://www.industrialservicefacility.it/wp-content/uploads/2025/03/logo-gray-1.png"
          alt="Industrial Service & Facility"
          class="footer-logo"
        />
        <p>Energia che costruisce valore, dal 2017.</p>
      </div>
      <div class="footer-right">
        <a href="https://www.industrialservicefacility.it/privacy-policy/" target="_blank" rel="noopener" class="footer-link">
          Privacy Policy
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
        <a href="https://www.industrialservicefacility.it/" target="_blank" rel="noopener" class="footer-link">
          Sito principale
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
      </div>
    </div>
  </footer>

</Layout>

<style is:global>
  /* ===== HEADER ===== */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-gray-200);
    transition: box-shadow 0.3s;
  }
  .header.scrolled {
    box-shadow: var(--shadow-sm);
  }
  .header-inner {
    max-width: 1140px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    padding: 0 28px;
  }
  .logo-link { display: flex; align-items: center; }
  .logo { height: 36px; width: auto; }
  .header-nav {
    display: flex;
    gap: 28px;
  }
  .nav-link {
    color: var(--color-gray-700);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-link:hover { color: var(--color-primary); }
  .header-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-primary);
    color: var(--color-white);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 8px 20px;
    border-radius: 100px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: all 0.25s;
  }
  .header-cta:hover {
    background: var(--color-primary-dark);
    box-shadow: 0 4px 16px rgba(13,158,113,0.25);
  }
  .pulse-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.9);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.4); }
  }

  /* ===== CONTAINER ===== */
  .container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 28px;
  }

  /* ===== HERO ===== */
  .hero {
    position: relative;
    padding: 140px 0 100px;
    background: var(--color-white);
    overflow: hidden;
  }
  .hero-deco {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .hero-circle {
    position: absolute;
    border-radius: 50%;
  }
  .hero-circle--1 {
    width: 500px;
    height: 500px;
    top: -120px;
    right: -80px;
    background: radial-gradient(circle, rgba(13,158,113,0.06) 0%, transparent 70%);
  }
  .hero-circle--2 {
    width: 300px;
    height: 300px;
    bottom: -60px;
    left: -40px;
    background: radial-gradient(circle, rgba(14,165,233,0.04) 0%, transparent 70%);
  }
  .hero-content {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 64px;
    align-items: center;
  }
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .eyebrow-tag {
    background: var(--color-primary-bg);
    padding: 4px 12px;
    border-radius: 100px;
  }
  .eyebrow-sep { color: var(--color-gray-400); }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4.5vw, 3.2rem);
    font-weight: 700;
    line-height: 1.12;
    color: var(--color-dark);
    letter-spacing: -0.025em;
    margin-bottom: 20px;
  }
  .title-highlight {
    color: var(--color-primary);
  }
  .hero-sub {
    font-size: 1.05rem;
    color: var(--color-gray-700);
    line-height: 1.75;
    margin-bottom: 36px;
    max-width: 500px;
  }
  .hero-actions { display: flex; gap: 14px; }

  .hero-photo-card {
    position: relative;
    min-height: 480px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid rgba(17, 17, 17, 0.08);
    box-shadow: 0 18px 48px rgba(17, 24, 39, 0.14);
    background: var(--color-gray-100);
  }
  .hero-photo {
    width: 100%;
    height: 100%;
    min-height: 480px;
    display: block;
    object-fit: cover;
    object-position: 58% center;
  }
  .hero-photo-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 48%, rgba(0,0,0,0.52) 100%);
    pointer-events: none;
  }
  .hero-photo-caption {
    position: absolute;
    left: 22px;
    right: 22px;
    bottom: 22px;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
    color: var(--color-white);
    font-size: 0.88rem;
    line-height: 1.45;
  }
  .caption-kicker {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.76);
  }

  /* ===== BUTTONS ===== */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.93rem;
    border: none;
    cursor: pointer;
    border-radius: var(--radius-md);
    transition: all 0.25s var(--ease-out-expo);
    text-decoration: none;
  }
  .btn-primary {
    background: var(--color-primary);
    color: var(--color-white);
    padding: 14px 28px;
  }
  .btn-primary:hover {
    background: var(--color-primary-dark);
    transform: translateY(-1px);
    box-shadow: 0 6px 24px rgba(13,158,113,0.2);
  }
  .btn-primary:active { transform: translateY(0); }
  .btn-lg {
    padding: 16px 32px;
    font-size: 0.95rem;
    border-radius: var(--radius-lg);
  }

  /* ===== SECTION COMMON ===== */
  .section-header { margin-bottom: 52px; }
  .section-tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    margin-bottom: 14px;
    padding: 5px 14px;
    border-radius: 100px;
    background: var(--color-primary-bg);
  }
  h2 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    font-weight: 700;
    color: var(--color-dark);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 12px;
  }
  .section-desc {
    font-size: 1rem;
    color: var(--color-gray-700);
    max-width: 460px;
    line-height: 1.65;
  }

  /* ===== WHY US ===== */
  .why-section {
    padding: 100px 0;
    background: var(--color-gray-50);
    border-top: 1px solid var(--color-gray-200);
    border-bottom: 1px solid var(--color-gray-200);
  }
  .why-visual {
    position: relative;
    min-height: 360px;
    margin-bottom: 28px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-gray-200);
    background: var(--color-gray-100);
  }
  .why-visual-img {
    width: 100%;
    height: 100%;
    min-height: 360px;
    display: block;
    object-fit: cover;
    object-position: center;
  }
  .why-visual::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.18) 42%, transparent 74%);
    pointer-events: none;
  }
  .why-visual-copy {
    position: absolute;
    left: 32px;
    bottom: 30px;
    z-index: 1;
    max-width: 340px;
    color: var(--color-white);
  }
  .why-visual-tag {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
    color: rgba(255,255,255,0.72);
  }
  .why-visual-copy p {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .benefit-card {
    padding: 32px 24px;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    transition: all 0.3s var(--ease-out-expo);
  }
  .benefit-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: rgba(13,158,113,0.2);
  }
  .benefit-icon-wrap {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary-bg);
    color: var(--color-primary);
    border-radius: var(--radius-md);
    margin-bottom: 20px;
  }
  .benefit-card h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-dark);
    margin-bottom: 8px;
  }
  .benefit-card p {
    font-size: 0.85rem;
    color: var(--color-gray-700);
    line-height: 1.6;
  }

  /* ===== GALLERY ===== */
  .gallery-section {
    padding: 100px 0;
    background: var(--color-white);
    border-bottom: 1px solid var(--color-gray-200);
  }
  .gallery {
    position: relative;
  }
  .gallery-track {
    overflow: hidden;
    padding: 4px 4px 24px;
    margin: 0 -4px;
  }
  .gallery-marquee {
    display: flex;
    gap: 20px;
    width: max-content;
    animation: gallery-marquee 58s linear infinite;
    will-change: transform;
  }
  .gallery-set {
    display: flex;
    gap: 20px;
  }
  @keyframes gallery-marquee {
    from { transform: translate3d(0, 0, 0); }
    to { transform: translate3d(calc(-50% - 10px), 0, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .gallery-marquee { animation: none; }
  }
  .gallery-slide {
    flex: 0 0 calc((min(100vw - 56px, 1084px) - 40px) / 3);
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-gray-100);
    border: 1px solid var(--color-gray-200);
    margin: 0;
    position: relative;
    transition: transform 0.3s var(--ease-out-expo), box-shadow 0.3s var(--ease-out-expo);
  }
  .gallery-slide:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .gallery-slide img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }
  .gallery-slide figcaption {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    padding: 18px 18px 16px;
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    background: linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.7) 100%);
    pointer-events: none;
  }
  .gallery-nav {
    display: none;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--color-gray-200);
    background: var(--color-white);
    color: var(--color-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    box-shadow: var(--shadow-md);
    transition: all 0.2s ease;
  }
  .gallery-nav:hover {
    background: var(--color-primary);
    color: var(--color-white);
    border-color: var(--color-primary);
  }
  .gallery-nav:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
  .gallery-nav-prev { left: -22px; }
  .gallery-nav-next { right: -22px; }

  /* ===== POSITIONS ===== */
  .positions-section {
    padding: 100px 0 120px;
    background: var(--color-white);
  }

  /* ===== PROFILE CARDS ===== */
  .profiles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    min-height: 220px;
  }
  .profiles-loading {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding: 40px 20px;
    color: var(--color-gray-500);
    font-size: 0.9rem;
  }
  .profiles-spinner {
    width: 28px;
    height: 28px;
    border: 3px solid var(--color-gray-200);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .profiles-empty {
    grid-column: 1 / -1;
    text-align: center;
    color: var(--color-gray-500);
    padding: 40px 20px;
    font-size: 0.95rem;
  }
  .profile-card {
    position: relative;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-xl);
    padding: 0;
    text-align: left;
    cursor: pointer;
    transition: all 0.3s var(--ease-out-expo);
    font-family: var(--font-body);
    overflow: hidden;
  }
  .card-top-accent {
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light));
    opacity: 0;
    transition: opacity 0.3s;
  }
  .profile-card:hover .card-top-accent { opacity: 1; }
  .profile-card:hover {
    border-color: rgba(13,158,113,0.25);
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
  }
  .profile-card > *:not(.card-top-accent) {
    padding: 0 28px;
  }
  .profile-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    padding-top: 28px !important;
    margin-bottom: 20px;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.68rem;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .badge-type {
    background: var(--color-olive);
    color: var(--color-white);
  }
  .badge-location {
    background: transparent;
    color: var(--color-primary);
    border: 1px solid var(--color-gray-200);
    font-weight: 500;
  }
  .profile-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary-bg);
    color: var(--color-primary);
    border-radius: var(--radius-md);
    margin-bottom: 16px;
  }
  .profile-card h3 {
    font-family: var(--font-display);
    font-size: 1.12rem;
    font-weight: 600;
    color: var(--color-dark);
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }
  .profile-card p {
    font-size: 0.85rem;
    color: var(--color-gray-700);
    margin-bottom: 24px;
    line-height: 1.6;
  }
  .profile-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 18px !important;
    padding-bottom: 28px !important;
    border-top: 1px solid var(--color-gray-100);
  }
  .ral-label {
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-gray-500);
    display: block;
    margin-bottom: 1px;
  }
  .ral-value {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-dark);
  }
  .profile-cta {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    transition: gap 0.25s var(--ease-out-expo);
  }
  .profile-card:hover .profile-cta { gap: 9px; }

  /* ===== QUESTIONNAIRE — KAHOOT-STYLE ===== */
  .questionnaire {
    --opt-green:  #16a34a;
    --opt-blue:   #0284c7;
    --opt-orange: #ea580c;
    --opt-violet: #7c3aed;

    max-width: 760px;
    margin: 0 auto;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 28px;
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08), 0 1px 0 rgba(255,255,255,0.6) inset;
    overflow: hidden;
    position: relative;
    animation: qSlideUp 0.5s var(--ease-out-expo);
  }
  .questionnaire::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 0% 0%, rgba(13,158,113,0.05) 0%, transparent 40%),
      radial-gradient(circle at 100% 100%, rgba(14,165,233,0.05) 0%, transparent 45%);
    pointer-events: none;
  }
  @keyframes qSlideUp {
    from { opacity: 0; transform: translateY(28px) scale(0.985); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes qFadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes qPop {
    0%   { transform: scale(1); }
    40%  { transform: scale(1.04); }
    100% { transform: scale(1); }
  }

  /* HEADER */
  .q-header {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 20px 28px;
    border-bottom: 1px solid var(--color-gray-100);
    background: linear-gradient(180deg, #fafbfc 0%, #f4f6f8 100%);
    position: relative;
    z-index: 1;
  }
  .q-back {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    cursor: pointer;
    color: var(--color-gray-700);
    height: 40px;
    padding: 0 14px 0 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    border-radius: 12px;
    transition: all 0.2s var(--ease-out-expo);
    box-shadow: 0 1px 2px rgba(0,0,0,0.04);
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .q-back-label { line-height: 1; }
  .q-back:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    transform: translateX(-2px);
  }
  .q-progress-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .q-progress-bar {
    flex: 1;
    height: 10px;
    background: var(--color-gray-100);
    border-radius: 100px;
    overflow: hidden;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.04);
  }
  .q-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--color-primary) 0%, var(--color-primary-light) 50%, #34d399 100%);
    border-radius: 100px;
    transition: width 0.55s var(--ease-out-expo);
    width: 0%;
    box-shadow: 0 0 12px rgba(13,158,113,0.4);
  }
  .q-progress-text {
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--color-dark);
    white-space: nowrap;
    min-width: 50px;
    letter-spacing: -0.01em;
  }
  .q-progress-text .q-progress-current {
    color: var(--color-primary);
    font-size: 1.1rem;
  }
  .q-profile-badge {
    font-size: 0.72rem;
    font-weight: 700;
    padding: 7px 14px;
    border-radius: 100px;
    background: var(--color-primary);
    color: var(--color-white);
    white-space: nowrap;
    letter-spacing: 0.02em;
    box-shadow: 0 2px 8px rgba(13,158,113,0.25);
  }

  /* BODY */
  .q-body {
    padding: 56px 48px 48px;
    min-height: 380px;
    position: relative;
    z-index: 1;
  }
  .q-question-wrap {
    width: 100%;
    animation: qFadeIn 0.4s var(--ease-out-expo);
  }
  .q-step-label {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-primary);
    margin-bottom: 18px;
    background: var(--color-primary-bg);
    padding: 6px 14px;
    border-radius: 100px;
  }
  .q-question {
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 2.4vw, 1.85rem);
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 10px;
    line-height: 1.25;
    letter-spacing: -0.02em;
  }
  .q-hint {
    font-size: 0.88rem;
    color: var(--color-gray-500);
    margin-bottom: 36px;
    line-height: 1.5;
    font-style: italic;
  }

  /* INTRO — pre-questionario */
  .q-intro-steps {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 24px;
  }
  .q-intro-step {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 18px 20px;
    background: var(--color-gray-50);
    border-radius: 14px;
    border: 1px solid var(--color-gray-100);
  }
  .q-intro-num {
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: var(--color-white);
    border-radius: 100px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    box-shadow: 0 4px 12px rgba(13,158,113,0.25);
  }
  .q-intro-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }
  .q-intro-text strong {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.02rem;
    color: var(--color-dark);
    letter-spacing: -0.01em;
  }
  .q-intro-text span {
    color: var(--color-gray-700);
    font-size: 0.92rem;
    line-height: 1.55;
  }
  .q-intro-text em {
    font-style: normal;
    color: var(--color-primary);
    font-weight: 600;
  }
  .q-intro-meta {
    display: flex;
    gap: 22px;
    margin-bottom: 22px;
    flex-wrap: wrap;
  }
  .q-intro-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-display);
    font-size: 0.88rem;
    color: var(--color-gray-700);
    font-weight: 600;
  }
  .q-intro-meta-item svg {
    color: var(--color-primary);
  }

  /* OPTIONS — generic (contact step uses this without --quiz modifier) */
  .q-options {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* QUIZ OPTIONS — Kahoot-style colored tiles */
  .q-options--quiz {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .q-option--quiz {
    --opt-bg: var(--opt-green);
    position: relative;
    display: flex;
    align-items: center;
    gap: 16px;
    width: 100%;
    padding: 22px 24px;
    border: 2px solid transparent;
    border-radius: 18px;
    background: var(--opt-bg);
    color: var(--color-white);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    text-align: left;
    cursor: pointer;
    transition: transform 0.25s var(--ease-out-expo), box-shadow 0.25s var(--ease-out-expo), filter 0.2s;
    box-shadow: 0 6px 0 rgba(0,0,0,0.12), 0 10px 20px rgba(15,23,42,0.08);
    overflow: hidden;
    line-height: 1.3;
  }
  .q-option--quiz[data-color="green"]  { --opt-bg: var(--opt-green); }
  .q-option--quiz[data-color="blue"]   { --opt-bg: var(--opt-blue); }
  .q-option--quiz[data-color="orange"] { --opt-bg: var(--opt-orange); }
  .q-option--quiz[data-color="violet"] { --opt-bg: var(--opt-violet); }

  .q-option--quiz::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255,255,255,0.15) 0%, transparent 50%);
    pointer-events: none;
  }
  .q-option--quiz:hover {
    transform: translateY(-3px);
    box-shadow: 0 9px 0 rgba(0,0,0,0.12), 0 16px 28px rgba(15,23,42,0.14);
    filter: brightness(1.06);
  }
  .q-option--quiz:active {
    transform: translateY(2px);
    box-shadow: 0 2px 0 rgba(0,0,0,0.12), 0 4px 10px rgba(15,23,42,0.1);
  }
  .q-option--quiz.selected {
    animation: qPop 0.4s var(--ease-out-expo);
    box-shadow: 0 6px 0 rgba(0,0,0,0.18), 0 0 0 4px rgba(255,255,255,0.9), 0 0 0 6px var(--opt-bg);
  }
  .q-option-shape {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.22);
    border-radius: 10px;
    color: var(--color-white);
  }
  .q-option-label {
    flex: 1;
    position: relative;
    z-index: 1;
  }
  .q-option-check {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-white);
    color: var(--opt-bg);
    border-radius: 50%;
    opacity: 0;
    transform: scale(0.6) rotate(-30deg);
    transition: all 0.3s var(--ease-out-expo);
  }
  .q-option--quiz.selected .q-option-check {
    opacity: 1;
    transform: scale(1) rotate(0);
  }

  /* CONTACT FIELDS */
  .q-input-row {
    display: flex;
    flex-direction: row;
    gap: 48px;
    width: 100%;
  }
  .q-input-row > .q-input-group {
    flex: 1 1 0;
    min-width: 0;
    margin-bottom: 20px;
  }
  .q-input-group { margin-bottom: 20px; min-width: 0; }
  .q-input-group label {
    display: block;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-gray-700);
    margin-bottom: 8px;
    letter-spacing: 0.01em;
  }
  .q-input-group label::after {
    content: '';
  }
  .q-input {
    display: block;
    width: 100%;
    max-width: 100%;
    padding: 14px 16px;
    border: 2px solid #d1d5db;
    border-radius: 14px;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-gray-900);
    transition: border-color 0.2s, background 0.2s;
    background: var(--color-white);
    box-shadow: none;
  }
  .q-input::placeholder { color: var(--color-gray-400); }
  .q-input:hover {
    border-color: #9ca3af;
  }
  .q-input:focus {
    outline: none;
    border-color: var(--color-primary);
    background: var(--color-white);
  }
  .q-input-group select.q-input {
    appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='14' height='10' viewBox='0 0 14 10' fill='none'><path d='M1 1.5 L7 8 L13 1.5' stroke='%230d9e71' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/></svg>");
    background-repeat: no-repeat;
    background-position: right 18px center;
    padding-right: 44px;
    cursor: pointer;
  }
  .q-submit {
    margin-top: 10px;
    padding: 18px 28px;
    font-size: 1rem;
    border-radius: 14px;
    box-shadow: 0 4px 0 rgba(0,0,0,0.12), 0 10px 24px rgba(13,158,113,0.25);
    transition: transform 0.2s var(--ease-out-expo), box-shadow 0.2s;
  }
  .q-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 0 rgba(0,0,0,0.12), 0 14px 28px rgba(13,158,113,0.3);
  }
  .q-submit:active {
    transform: translateY(1px);
    box-shadow: 0 2px 0 rgba(0,0,0,0.12), 0 4px 10px rgba(13,158,113,0.2);
  }
  .q-privacy {
    font-size: 0.74rem;
    color: var(--color-gray-500);
    text-align: center;
    margin-top: 18px;
    line-height: 1.7;
