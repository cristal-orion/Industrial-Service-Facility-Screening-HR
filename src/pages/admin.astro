    if (!btn) return;
    const cat = btn.dataset.cat;
    if (state.catActive.has(cat)) {
      state.catActive.delete(cat);
      btn.classList.remove('active');
    } else {
      state.catActive.add(cat);
      btn.classList.add('active');
    }
    renderAll();
  });

  function filterCandidates() {
    return CANDIDATES.filter(c => {
      if (state.posizione && c.posizione !== state.posizione) return false;
      if (!state.catActive.has(c.categoria)) return false;
      if (state.search) {
        const hay = `${c.nome} ${c.cognome} ${c.email}`.toLowerCase();
        if (!hay.includes(state.search)) return false;
      }
      return true;
    });
  }

