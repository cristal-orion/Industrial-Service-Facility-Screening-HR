              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </div>
        </button>
      `;
    }).join('');
    profilesGrid.innerHTML = html;
    // riattacca animazione reveal alle nuove card
    profilesGrid.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  }

  function applyPositions(list) {
    POSITIONS_LIST = (list || []).slice().sort((a, b) => (a.ordine - b.ordine) || a.titolo.localeCompare(b.titolo));
    POSITIONS = {};
    for (const p of POSITIONS_LIST) POSITIONS[p.id] = p.titolo;
  }

  async function loadPositions() {
    let list = null;
    if (WEBHOOK_URL) {
      try {
        const res = await fetch(WEBHOOK_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'text/plain;charset=utf-8' },
          body: JSON.stringify({ action: 'list_positions' })
        });
        if (res.ok) {
          const data = await res.json();
          if (data && data.ok && Array.isArray(data.positions) && data.positions.length) {
            list = data.positions;
          }
        }
      } catch (err) {
        console.warn('Fallback posizioni hardcoded:', err);
      }
    }
    applyPositions(list || FALLBACK_POSITIONS);
    renderProfilesGrid();
  }

  // popola subito col fallback (così select del contact step ha sempre valori),
  // poi sovrascrive col risultato del fetch
  applyPositions(FALLBACK_POSITIONS);
  loadPositions();

  function startQuiz(positionKey) {
    selectedPosition = positionKey;
    currentStep = -1;
    contact = { nome: '', cognome: '', email: '', telefono: '', citta: '' };
    answers = new Array(QUESTIONS.length).fill(null);

    profilesGrid.style.display = 'none';
    resultScreen.style.display = 'none';
    questionnaire.style.display = 'block';
    qProfileBadge.textContent = POSITIONS[selectedPosition] || '';

    questionnaire.scrollIntoView({ behavior: 'smooth', block: 'center' });
    renderStep();
  }

  // ===== RENDER STEP =====
  function renderStep() {
    if (currentStep === -1) {
      qProgressWrap.style.visibility = 'hidden';
      qProgress.style.width = '0%';
    } else {
      qProgressWrap.style.visibility = 'visible';
      const pct = ((currentStep + 1) / TOTAL_STEPS) * 100;
      qProgress.style.width = pct + '%';
      qProgressText.innerHTML = `<span class="q-progress-current">${currentStep + 1}</span> / ${TOTAL_STEPS}`;
    }

    qQuestionWrap.style.animation = 'none';
    qQuestionWrap.offsetHeight;
    qQuestionWrap.style.animation = 'fadeIn 0.35s var(--ease-out-expo)';

    if (currentStep === -1) {
      renderIntroStep();
    } else if (currentStep === 0) {
      renderContactStep();
    } else {
      renderQuestionStep(currentStep - 1);
    }
  }

  function renderIntroStep() {
    qStepLabel.textContent = 'Prima di iniziare';
    qQuestion.textContent = 'Come funziona il questionario';
    qHint.textContent = '';
    qHint.style.display = 'none';
    qOptions.classList.remove('q-options--quiz');

    qOptions.innerHTML = `
      <div class="q-intro-steps">
        <div class="q-intro-step">
          <span class="q-intro-num">1</span>
          <div class="q-intro-text">
            <strong>I tuoi dati</strong>
            <span>Nome, contatti e posizione di interesse. Meno di un minuto.</span>
          </div>
        </div>
        <div class="q-intro-step">
          <span class="q-intro-num">2</span>
          <div class="q-intro-text">
            <strong>16 domande attitudinali</strong>
            <span>Una alla volta, con 4 opzioni di risposta. <em>Non ci sono risposte giuste o sbagliate</em>: rispondi onestamente, ci serve per capire l'affinità col ruolo.</span>
          </div>
        </div>
        <div class="q-intro-step">
          <span class="q-intro-num">3</span>
          <div class="q-intro-text">
            <strong>Esito</strong>
            <span>Se il tuo profilo è in linea con la posizione, il nostro team HR ti ricontatterà per i prossimi passi.</span>
          </div>
        </div>
      </div>
      <div class="q-intro-meta">
        <span class="q-intro-meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          ~ 5 minuti
        </span>
        <span class="q-intro-meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Dati protetti (GDPR)
        </span>
        <span class="q-intro-meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
          Puoi tornare indietro
        </span>
      </div>
      <button class="btn btn-primary q-submit" id="qIntroStart" type="button" style="width:100%;justify-content:center;">
        Inizia ora
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </button>
    `;
    document.getElementById('qIntroStart').addEventListener('click', () => {
      currentStep = 0;
      renderStep();
    });
  }

  function renderContactStep() {
    qStepLabel.textContent = 'I tuoi dati';
    qQuestion.textContent = 'Iniziamo con qualche informazione su di te';
    qHint.textContent = 'Useremo questi dati solo per ricontattarti.';
    qHint.style.display = '';
    qOptions.classList.remove('q-options--quiz');

    const positionOptions = POSITIONS_LIST
      .map(p => `<option value="${escapeAttr(p.id)}" ${p.id === selectedPosition ? 'selected' : ''}>${escapeHtml(p.titolo)}</option>`)
      .join('');

    qOptions.innerHTML = `
      <div class="q-input-row">
        <div class="q-input-group">
          <label for="qNome">Nome *</label>
          <input type="text" id="qNome" class="q-input" placeholder="Mario" value="${escapeAttr(contact.nome)}" required />
        </div>
        <div class="q-input-group">
          <label for="qCognome">Cognome *</label>
          <input type="text" id="qCognome" class="q-input" placeholder="Rossi" value="${escapeAttr(contact.cognome)}" required />
        </div>
      </div>
      <div class="q-input-group">
        <label for="qEmail">Email *</label>
        <input type="email" id="qEmail" class="q-input" placeholder="mario.rossi@email.com" value="${escapeAttr(contact.email)}" required />
      </div>
      <div class="q-input-row">
        <div class="q-input-group">
          <label for="qTelefono">Telefono *</label>
          <input type="tel" id="qTelefono" class="q-input" placeholder="+39 333 1234567" value="${escapeAttr(contact.telefono)}" required />
        </div>
        <div class="q-input-group">
          <label for="qCitta">Città *</label>
          <input type="text" id="qCitta" class="q-input" placeholder="Napoli" value="${escapeAttr(contact.citta)}" required />
        </div>
      </div>
      <div class="q-input-group">
        <label for="qPosizione">Posizione di interesse *</label>
        <select id="qPosizione" class="q-input">${positionOptions}</select>
      </div>

      <label class="q-consent" id="qConsentBox">
        <input type="checkbox" id="qPrivacy" />
        <span class="q-consent-text">
          <strong>Accetto la Privacy Policy</strong> e acconsento al trattamento dei miei dati personali per finalità di selezione del personale, ai sensi del GDPR (Reg. UE 2016/679). <a href="https://www.industrialservicefacility.it/privacy-policy/" target="_blank" rel="noopener" class="q-privacy-link">Leggi l'informativa completa</a>.
        </span>
      </label>

      <div class="q-consent-error" id="qContactError"></div>

      <button class="btn btn-primary q-submit" id="qStart" style="width:100%;justify-content:center;margin-top:16px;">
        Inizia il questionario
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </button>
    `;
    const consentBox = document.getElementById('qConsentBox');
    const privacyCb = document.getElementById('qPrivacy');
    privacyCb.addEventListener('change', () => {
      consentBox.classList.toggle('checked', privacyCb.checked);
    });
    document.getElementById('qStart').addEventListener('click', handleContactSubmit);
  }

  function showContactError(msg) {
    const el = document.getElementById('qContactError');
    if (!el) return;
    el.textContent = msg;
    el.classList.add('visible');
  }
  function clearContactError() {
    const el = document.getElementById('qContactError');
    if (el) el.classList.remove('visible');
  }

  function renderQuestionStep(qIndex) {
    const q = QUESTIONS[qIndex];
    qStepLabel.textContent = `Domanda ${qIndex + 1} di ${QUESTIONS.length}`;
    qQuestion.textContent = q.text;
    qHint.textContent = '';
    qHint.style.display = 'none';

    qOptions.innerHTML = '';
    qOptions.classList.add('q-options--quiz');
    ANSWER_OPTIONS.forEach((opt, i) => {
      const btn = document.createElement('button');
      btn.className = 'q-option q-option--quiz';
      btn.dataset.color = opt.color;
      btn.innerHTML = `
        <span class="q-option-shape">${SHAPE_SVG[opt.shape]}</span>
        <span class="q-option-label">${opt.label}</span>
        <span class="q-option-check" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
      `;
      if (answers[qIndex] && answers[qIndex].value === opt.value) {
        btn.classList.add('selected');
      }
      btn.addEventListener('click', () => handleAnswer(qIndex, opt.value, i));
      qOptions.appendChild(btn);
    });

    questionStartTime = performance.now();
  }

  async function handleContactSubmit() {
    clearContactError();
    const nome = document.getElementById('qNome').value.trim();
    const cognome = document.getElementById('qCognome').value.trim();
    const email = document.getElementById('qEmail').value.trim();
    const telefono = document.getElementById('qTelefono').value.trim();
    const citta = document.getElementById('qCitta').value.trim();
    const posizione = document.getElementById('qPosizione').value;
    const privacyAccepted = document.getElementById('qPrivacy').checked;

    if (!nome || !cognome || !email || !telefono || !citta) {
      showContactError('Compila tutti i campi obbligatori.');
      return;
    }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showContactError('Inserisci un indirizzo email valido.');
      return;
    }
    if (!privacyAccepted) {
      showContactError('Per procedere devi accettare la Privacy Policy.');
      return;
    }

    const btn = document.getElementById('qStart');
    const originalHTML = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = 'Verifica in corso…';

    try {
      const dup = await checkDuplicate(email, telefono);
      if (dup === 'exists') {
        showContactError('Risulta già una candidatura con questa email o numero di telefono. Il questionario può essere svolto una sola volta. Per modifiche scrivici a HR.');
        btn.disabled = false;
        btn.innerHTML = originalHTML;
        return;
      }
      // Se il check fallisce per rete, lasciamo procedere — il submit finale ha comunque dedup
    } catch (_) { /* ignora, dedup garantito al submit */ }

    contact = { nome, cognome, email, telefono, citta };
    selectedPosition = posizione;
    qProfileBadge.textContent = POSITIONS[selectedPosition] || '';

    currentStep = 1;
    renderStep();
  }

  async function checkDuplicate(email, telefono) {
    if (!WEBHOOK_URL) return 'unknown';
    const res = await fetch(WEBHOOK_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'text/plain;charset=utf-8' },
      body: JSON.stringify({ action: 'check_duplicate', email, telefono })
    });
    if (!res.ok) throw new Error('check_duplicate http ' + res.status);
    const data = await res.json();
    if (data && data.ok && data.exists) return 'exists';
    return 'ok';
  }

  function handleAnswer(qIndex, value, optionIdx) {
    const opts = qOptions.querySelectorAll('.q-option');
    opts.forEach(o => o.classList.remove('selected'));
    opts[optionIdx].classList.add('selected');

    const timeMs = questionStartTime ? Math.round(performance.now() - questionStartTime) : null;
    answers[qIndex] = { questionId: QUESTIONS[qIndex].id, value, timeMs };

    setTimeout(() => {
      if (qIndex + 1 < QUESTIONS.length) {
        currentStep++;
        renderStep();
      } else {
        submitCandidatura();
      }
    }, 350);
  }

  async function submitCandidatura() {
    const payload = {
      posizione: POSITIONS[selectedPosition] || selectedPosition,
      posizioneKey: selectedPosition,
      contatto: contact,
      risposte: answers.map(a => a || { questionId: null, value: null, timeMs: null }),
      timestamp: new Date().toISOString(),
      userAgent: navigator.userAgent
    };

    // Log temporaneo finché non c'è il webhook configurato
    console.log('Candidatura payload:', payload);

    let outcome = 'ok';
    if (WEBHOOK_URL) {
      try {
        const res = await fetch(WEBHOOK_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'text/plain;charset=utf-8' },
          body: JSON.stringify(payload)
        });
        if (!res.ok) {
          outcome = 'error';
        } else {
          const data = await res.json().catch(() => ({}));
          if (data && data.ok === false && data.error === 'already_submitted') outcome = 'duplicate';
          else if (data && data.ok === false) outcome = 'error';
        }
      } catch (err) {
        console.error('Errore invio candidatura:', err);
        outcome = 'error';
      }
    }

    showThankYou(outcome);
  }

  function showThankYou(outcome) {
    // Compat: accetta vecchia firma boolean
    if (outcome === true)  outcome = 'ok';
    if (outcome === false) outcome = 'error';

    questionnaire.style.display = 'none';
    resultScreen.style.display = 'block';

    const icon = document.getElementById('resultIcon');
    const title = document.getElementById('resultTitle');
    const message = document.getElementById('resultMessage');
    const btn = document.getElementById('resultBtn');
    const invite = document.getElementById('resultInvite');

    if (outcome === 'ok') {
      icon.className = 'result-icon success';
      icon.innerHTML = `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
      title.textContent = 'Grazie, abbiamo ricevuto la tua candidatura';
      message.textContent = 'Il nostro team HR valuterà il tuo profilo nei prossimi giorni. Se sarà in linea con le nostre ricerche, ti contatteremo per i passi successivi.';
      btn.textContent = 'Torna alla home';
      btn.onclick = resetAll;
      if (invite) invite.style.display = 'block';
    } else if (outcome === 'duplicate') {
      icon.className = 'result-icon warning';
      icon.innerHTML = `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`;
      title.textContent = 'Hai già completato il questionario';
      message.textContent = 'Risulta già una candidatura inviata con la tua email o il tuo numero di telefono. Il questionario può essere svolto una sola volta. Se hai bisogno di modificare i tuoi dati, contatta il nostro team HR.';
      btn.textContent = 'Torna alla home';
      btn.onclick = resetAll;
      if (invite) invite.style.display = 'none';
    } else {
      icon.className = 'result-icon warning';
      icon.innerHTML = `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`;
      title.textContent = 'Qualcosa è andato storto';
      message.textContent = 'Non siamo riusciti a inviare la candidatura. Riprova tra qualche minuto oppure scrivici via email.';
      btn.textContent = 'Riprova';
      btn.onclick = () => { resultScreen.style.display = 'none'; questionnaire.style.display = 'block'; };
      if (invite) invite.style.display = 'none';
    }

    document.getElementById('resultScore').style.display = 'none';
    btn.style.display = 'inline-flex';

    resultScreen.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  qBack.addEventListener('click', () => {
    if (currentStep <= -1) {
      resetAll();
    } else {
      currentStep--;
      renderStep();
    }
  });

  function resetAll() {
    selectedPosition = null;
    currentStep = -1;
    contact = { nome: '', cognome: '', email: '', telefono: '', citta: '' };
    answers = new Array(QUESTIONS.length).fill(null);
    questionnaire.style.display = 'none';
    resultScreen.style.display = 'none';
    profilesGrid.style.display = 'grid';
    profilesGrid.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function escapeAttr(s) {
    return String(s || '').replace(/"/g, '&quot;').replace(/</g, '&lt;');
  }

  // ===== INVITA UN AMICO =====
  (function setupInvite() {
    const shareUrl = window.location.origin + window.location.pathname + '#candidatura';

    // popola tutti gli input invite presenti
    document.querySelectorAll('.invite-url').forEach(el => { el.value = shareUrl; });

    // bottone "Condividi" mobile (Web Share API)
    const shareBtn = document.getElementById('inviteShareBtn');
    if (shareBtn && typeof navigator.share === 'function') {
      shareBtn.style.display = 'inline-flex';
      shareBtn.addEventListener('click', async () => {
        try {
          await navigator.share({
            title: 'Industrial Service & Facility — posizioni aperte',
            text: 'Sto guardando le posizioni aperte da Industrial Service & Facility, potrebbe interessarti:',
            url: shareUrl
          });
        } catch (_) { /* utente ha annullato */ }
      });
    }

    // bottoni "Copia link" (anche dentro la result screen)
    document.querySelectorAll('.invite-copy-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const targetId = btn.dataset.target;
        const statusId = btn.dataset.status;
        const input = targetId ? document.getElementById(targetId) : null;
        const status = statusId ? document.getElementById(statusId) : null;
        const value = input ? input.value : shareUrl;
        let ok = false;
        try {
          await navigator.clipboard.writeText(value);
          ok = true;
        } catch (_) {
          // fallback: select + execCommand
          try {
            if (input) {
              input.select();
              input.setSelectionRange(0, 99999);
              ok = document.execCommand('copy');
            }
          } catch (_) {}
        }
        if (status) {
          status.textContent = ok ? '✓ Link copiato negli appunti' : 'Non riesco a copiare. Seleziona il link manualmente.';
          if (ok) setTimeout(() => { status.textContent = ''; }, 2500);
        }
        if (ok) {
          btn.classList.add('copied');
          const original = btn.innerHTML;
          btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Copiato';
          setTimeout(() => {
            btn.classList.remove('copied');
            btn.innerHTML = original;
          }, 2000);
        }
      });
    });
  })();
</script>
